# =============================================================================
# ensure_letsencrypt_structure() - Defensive Directory & File Pre-Creation
# =============================================================================
#
# CRITICAL DEFENSIVE FUNCTION
#
# Purpose:
#   Ensures /etc/letsencrypt and placeholder files exist.
#   Called early and often per the Defensive Pre-Creation Rule.
#
# Updated Behavior (April 2026):
#   • When run as root: create directories and files normally.
#   • When run as non-root: silently skip creation (for diagnostic commands
#     like "email", "domains", "about" that should work without sudo).
#   • This prevents ugly permission errors on stderr while still allowing
#     read operations to succeed gracefully ("No email configured yet").
#
# Updated in 1.9.0:
#   • Skips creation when not root (supports nginx-adm diagnostics)
#
# !!! DO NOT REMOVE THE ROOT CHECK !!!
# !!! CALL IT EARLY AND OFTEN !!!
# =============================================================================

ensure_letsencrypt_structure() {
    if [ "$(id -u)" -ne 0 ]; then
        return 0
    fi

    mkdir -p /etc/letsencrypt \
            /etc/letsencrypt/renewal \
            /etc/letsencrypt/live \
            /etc/letsencrypt/archive 2>/dev/null || true

    if [ ! -f "$EMAIL_FILE" ]; then
        touch "$EMAIL_FILE" 2>/dev/null || true
        chmod 600 "$EMAIL_FILE" 2>/dev/null || true
    fi

    if [ ! -f "$DOMAINS_FILE" ]; then
        touch "$DOMAINS_FILE" 2>/dev/null || true
        chmod 644 "$DOMAINS_FILE" 2>/dev/null || true
    fi
}

# =============================================================================
# create_nginx_adm_user() - Create dedicated least-privilege user (NEW 1.9.0)
# =============================================================================
#
# CRITICAL FUNCTION - PART OF nginx-adm LEAST-PRIVILEGE MODEL
#
# Purpose:
#   Creates the "nginx-adm" user if it does not exist.
#   This user will own all nginx configuration and will be used for day-to-day operations.
#
# Recent Improvement (April 2026 - Idempotency Enhancement):
#   • Added explicit early exit: if `nginx-adm` user already exists (`id "nginx-adm"`),
#     the function now returns immediately with a clear status message.
#   • This prevents unnecessary groupadd/useradd calls and reduces log noise on
#     repeated runs or when re-running the script after partial setup.
#   • Maintains full least-privilege model while making the function truly idempotent.
#
# Rules:
#   • User is a normal (non-root) system user.
#   • Home directory is set to /etc/nginx-adm (not under /home).
#   • Shell is /bin/bash.
#   • Group "nginx-adm" is also created.
#   • Idempotent: does nothing if user already exists.
#   • Fixed UID = 1999, GID = 1999
#
# !!! MUST BE CALLED EARLY IN BOTH INTERACTIVE AND NON-INTERACTIVE SETUP !!!
# =============================================================================

create_nginx_adm_user() {
    # Early exit if user already exists - respects idempotency
    if id "nginx-adm" >/dev/null 2>&1; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "status" "nginx-adm user already exists" "uid" "1999"
        else
            info "nginx-adm user already exists (UID/GID 1999)."
        fi
        return 0
    fi

    info "Creating nginx-adm user (UID/GID 1999)..."
    # Create group with fixed GID if it doesn't exist
    if ! getent group nginx-adm >/dev/null 2>&1; then
        groupadd -g 1999 nginx-adm 2>/dev/null || true
    fi

    # Create user if it doesn't exist
    if ! id "nginx-adm" >/dev/null 2>&1; then
        useradd -m -d /etc/nginx-adm \
                -g 1999 -u 1999 \
                -s /bin/bash \
                -c "Admin user for nginx configuration" \
                nginx-adm 2>/dev/null || true
    else
        info "nginx-adm user already exists."
    fi

    # Ensure home directory exists and has correct ownership
    mkdir -p /etc/nginx-adm 2>/dev/null || true
    chown nginx-adm:nginx-adm /etc/nginx-adm 2>/dev/null || true
    chmod 755 /etc/nginx-adm 2>/dev/null || true

    success "nginx-adm user (UID/GID 1999) created with home /etc/nginx-adm."
}

# =============================================================================
# setup_nginx_adm_ownership() - Set ownership and symlinks (Fixed for 1.9.0)
# =============================================================================
#
# CRITICAL FUNCTION - PART OF nginx-adm LEAST-PRIVILEGE MODEL
#
# Purpose:
#   Ensures nginx-adm owns the configuration and sets up correct symlinks:
#     ${NGINX_CONF_ROOT}/sites-available  → symlink to ${NGINX_CONF_ROOT}-adm/sites-available
#     ${NGINX_CONF_ROOT}/sites-enabled    → symlink to ${NGINX_CONF_ROOT}-adm/sites-enabled
#
# Important Rules:
#   • Does NOT recreate user (only ownership and symlinks)
#   • Real directories live under ${NGINX_CONF_ROOT}/ (never delete them)
#   • Only create symlinks in /etc/nginx-adm/ if they don't exist or are broken
#   • Preserves existing files in /etc/nginx-adm when user is recreated
#   • Never need to create /etc/nginx-adm (which is the home directory of user: nginx-adm)
#   • Correct symlink direction: ${NGINX_CONF_ROOT}/sites-* → /etc/nginx-adm/sites-*
#   • Never rm -rf real config directories
#   • Ownership: nginx-adm:root (as per your test)
#   • Permissions: 775 for practical group access
#   • not working in /bin/sh mkdir -p ${NGINX_CONF_ROOT}/{sites-available,sites-enabled}
#
# !!! MUST BE CALLED AFTER create_nginx_adm_user() !!!
# =============================================================================

setup_nginx_adm_ownership() {
    info "Setting nginx-adm ownership and symlinks..."

    # 1. Ensure real directories exist under nginx (never delete content)
    # Under /bin/sh, the following is not working, you should do it one by one
    # mkdir -p ${NGINX_CONF_ROOT}/{sites-available,sites-enabled}
    mkdir -p ${NGINX_CONF_ROOT}/sites-available
    mkdir -p ${NGINX_CONF_ROOT}/sites-enabled


    # 3. Transfer ownership
    chown -R nginx-adm:root ${NGINX_CONF_ROOT} 2>/dev/null || true

    # 4. Create symlinks in ${NGINX_CONF_ROOT}/ pointing to /etc/nginx-adm/ (correct direction)
    for dir in sites-available sites-enabled; do
        local source="${NGINX_CONF_ROOT}/${dir}"
        local target="/etc/nginx-adm/${dir}"

        # If the target is NOT already a symlink to the correct location, fix it
        if [ ! -L "${target}" ] || [ "$(readlink "${target}")" != "${source}" ]; then

            # If it's a real directory, back it up first (safety)
            if [ -d "${target}" ] && [ ! -L "${target}" ]; then
                local today=$(date +%Y%m%d)
                local count=1
                while [ -f "${target}.${today}-${count}.bak" ]; do
                    count=$((count + 1))
                done
                cp -a "${target}" "${target}.${today}-${count}.bak" 2>/dev/null || true
                info "Backed up real directory ${target} before creating symlink."
                rm -rf "${target}" 2>/dev/null || true
            fi

            ln -sf "${source}" "${target}"
            info "Created/updated symlink: ${target} → ${source}"
        fi
    done

    # 5. Set permissions
    chmod 775 ${NGINX_CONF_ROOT} 2>/dev/null || true
    chmod 775 /etc/nginx-adm/sites-available 2>/dev/null || true
    chmod 775 /etc/nginx-adm/sites-enabled 2>/dev/null || true

    success "nginx-adm ownership and correct symlinks configured."
}

# =============================================================================
# setup_restricted_sudoers() - Create restricted sudoers for nginx-adm (NEW 1.9.0)
# =============================================================================
#
# CRITICAL FUNCTION - PART OF nginx-adm LEAST-PRIVILEGE MODEL
#
# Purpose:
#   Creates or updates the sudoers.d file for nginx-adm with restricted permissions.
#
# New Behavior (as requested):
#   • If /etc/sudoers.d/nginx-adm already exists, it is backed up to /etc/sudoers.bak/
#     using dated format: nginx-adm.YYYYMMDD-N.bak (N increments per day)
#   • Creates the backup directory if it doesn't exist
#   • Always writes fresh, clean sudoers content after backup
#   • Validates syntax with visudo when possible
#   • File must end with a blank line (sudoers requirement)
#
# !!! MUST BE CALLED AFTER create_nginx_adm_user() !!!
# =============================================================================

setup_restricted_sudoers() {
    local sudoers_file="/etc/sudoers.d/nginx-adm"
    local backup_dir="/etc/sudoers.bak"

    info "Setting up restricted sudoers for nginx-adm..."

    # Create backup directory if it doesn't exist
    mkdir -p "${backup_dir}" 2>/dev/null || true
    chmod 755 "${backup_dir}" 2>/dev/null || true

    # Backup existing sudoers file if it exists
    if [ -f "${sudoers_file}" ]; then
        local today
        today=$(date +%Y%m%d)

        # Find next backup number for today
        local count=1
        while [ -f "${backup_dir}/nginx-adm.${today}-${count}.bak" ]; do
            count=$((count + 1))
        done

        local backup_file="${backup_dir}/nginx-adm.${today}-${count}.bak"

        cp -a "${sudoers_file}" "${backup_file}" 2>/dev/null || true
        info "Backed up existing sudoers file → ${backup_file}"
    fi

    # Write the new restricted sudoers file (remember leave a blank line at the end)
    cat > "${sudoers_file}" << 'EOF'
# nginx-adm restricted sudoers - certbot-nginx
# Allows nginx-adm to control nginx service without password (least privilege)
nginx-adm ALL=(ALL) NOPASSWD: /bin/systemctl start nginx
nginx-adm ALL=(ALL) NOPASSWD: /bin/systemctl stop nginx
nginx-adm ALL=(ALL) NOPASSWD: /bin/systemctl reload nginx
nginx-adm ALL=(ALL) NOPASSWD: /bin/systemctl restart nginx
nginx-adm ALL=(ALL) NOPASSWD: /bin/systemctl restart nginx
nginx-adm ALL=(ALL) NOPASSWD: /bin/journalctl -u nginx
nginx-adm ALL=(ALL) NOPASSWD: /usr/bin/systemctl start nginx
nginx-adm ALL=(ALL) NOPASSWD: /usr/bin/systemctl stop nginx
nginx-adm ALL=(ALL) NOPASSWD: /usr/bin/systemctl reload nginx
nginx-adm ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart nginx
nginx-adm ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart nginx
nginx-adm ALL=(ALL) NOPASSWD: /usr/bin/journalctl -u nginx
nginx-adm ALL=(ALL) NOPASSWD: /usr/sbin/nginx

EOF

    chmod 0440 "${sudoers_file}" 2>/dev/null || true
    chown root:root "${sudoers_file}" 2>/dev/null || true

    # Defensive syntax validation
    if command -v visudo >/dev/null 2>&1; then
        if ! visudo -cf "${sudoers_file}" >/dev/null 2>&1; then
            warn "Warning: sudoers file syntax check failed. Please review ${sudoers_file}"
        fi
    fi

    success "Restricted sudoers for nginx-adm configured successfully."
}

# =============================================================================
# backup_nginx_sites_configs() - Dated backup with special default.conf handling (NEW 1.9.0)
# =============================================================================
#
# CRITICAL FUNCTION - PART OF BACKUP POLICY
#
# Purpose:
#   Creates dated backups before modifying nginx configs.
#   Special rule: default.conf is backed up then removed (prevents accumulation on repeated runs).
#
#   Does NOT backup the main nginx.conf (that is handled separately when we
#   modify it once for sites-enabled support).
#
# Why this name?
#   Previous name `backup_existing_nginx_configs` was blurry — it suggested
#   it backs up everything. This new name makes intention explicit and accurate.
#
# Backup format: <filename>.YYYYMMDD-N.bak   (N = daily counter starting at 1)
#
# Rules:
#   • Backs up files in ${NGINX_CONF_ROOT}/sites-available/
#   • For default.conf (or default site files): backup then delete original
#   • Other files: backup only (keep original)
#   • Idempotent and defensive
#
# !!! MUST BE CALLED BEFORE ANY CONFIG CREATION OR REMOVAL !!!
# =============================================================================

backup_nginx_sites_configs() {
    local sites_dir="${NGINX_CONF_ROOT}/sites-available"
    local today
    today=$(date +%Y%m%d)

    [ ! -d "$sites_dir" ] && return 0

    info "Creating dated backup of existing nginx configurations..."

    for conf in "$sites_dir"/*.conf; do
        [ ! -f "$conf" ] && continue

        local base_name
        base_name=$(basename "$conf")

        # Count existing backups for today
        local count=1
        while [ -f "${conf}.${today}-${count}.bak" ]; do
            count=$((count + 1))
        done

        local backup_file="${conf}.${today}-${count}.bak"

        cp -a "$conf" "$backup_file" 2>/dev/null || true
        chown nginx-adm:nginx-adm "$backup_file" 2>/dev/null || true

        info "Backed up: ${base_name} → ${backup_file}"

        # Special rule for default.conf: remove original after backup
        if [ "$base_name" = "default.conf" ] || echo "$base_name" | grep -qE '^default'; then
            rm -f "$conf" 2>/dev/null || true
            info "Removed original default.conf after backup (per policy)."
        fi
    done

    success "Nginx configuration backup completed."
}

# =============================================================================
# main_certbot_nginx_app() - Main Entry Point and Command Dispatcher
# =============================================================================
#
# CRITICAL FUNCTION - SINGLE SOURCE OF TRUTH FOR SCRIPT EXECUTION FLOW
#
# Purpose:
#   This is the central dispatcher for the entire script. It handles:
#     • Auto-install logic for the classic one-liner (curl | sh)
#     • Flag parsing (--quiet, --json, --force, etc.)
#     • Command routing (run, about, version, domains, email, nginx-conf, etc.)
#     • Interactive vs non-interactive mode decision
#
# Alignment with CRITICAL REQUIREMENTS (Header):
#   • Maintains the strict installation and configuration sequence
#   • Supports --quiet and --json modes fully in ALL paths
#   • Preserves the "install first → stop nginx → handle email/domains → certs → config" order
#   • Never starts nginx early or allows partial configurations
#
# Platform Awareness (2026):
#   • Install functions (install_certbot / install_nginx) now support multiple platforms
#     (Linux apt/apk/dnf, macOS Homebrew, warnings on Git Bash).
#   • Core logic (certbot --standalone, nginx config) remains Linux-centric.
#   • Unsupported platforms (Git Bash, native Windows) are handled gracefully with warnings.
#
# Auto-Install Behavior (Defensive):
#   • When the script is NOT installed and no arguments are given, it offers
#     (or automatically performs) self-installation.
#   • This powers the popular `curl | sh` one-liner.
#   • The block MUST stay at the very top, before any argument parsing.
#
# Command Parsing Rules:
#   • Flags are parsed first (--quiet, --json, --force, etc.)
#   • Then the main command is determined (default = "run")
#   • Sub-commands like "domains", "email", "nginx-conf" bypass the full setup
#
# Defensive Design:
#   • All output goes through output_text() or output_json()
#   • Repeated safe defaults (: "${VAR:=default}")
#   • Clear separation between interactive and non-interactive paths
#   • Unknown commands produce clear errors (with JSON support)
#
# Important Rules:
#   • The full interactive setup (email + main domain + certs + nginx config)
#     can ONLY be completed in TTY mode.
#   • Non-interactive mode only installs packages and stops nginx — it forces
#     the user to run interactively for the rest.
#
# Changes in 1.9.0:
#   • Added nginx-adm setup in both interactive and non-interactive paths
#   • Created and integrated run_non_interactive_setup() for root-only install-only mode
#   • Ensured backup and nginx-adm functions are called where configuration is touched
#   • Non-interactive mode now respects the new least-privilege model (when run as root)
#
# !!! THIS FUNCTION IS THE SINGLE ENTRY POINT !!!
# !!! DO NOT MOVE THE AUTO-INSTALL BLOCK !!!
# !!! DO NOT COMBINE OR REFACTOR COMMAND PARSING !!!
# !!! PRESERVE THE STRICT SEQUENCE IN ALL DISPATCHED PATHS !!!
# !!! PREVIOUS GROK INSTANCES TRIED TO "CLEAN UP" THIS FUNCTION — DO NOT !!!
# =============================================================================

main_certbot_nginx_app() {
    # Safe defaults (repeated on purpose - defensive style)
    : "${HOME:=/root}"
    : "${GLOBAL_BIN:=/usr/local/bin}"
    : "${QUIET:=0}"
    : "${JSON:=0}"
    : "${USE_CLOUDFLARE:=1}"   # Default: enable Cloudflare protection

    local COMMAND="run"

    # =============================================================================
    # AUTO-INSTALL FOR ONE-LINER (curl | sh) - MUST STAY AT THE TOP
    # =============================================================================
    if ! is_installed && [ $# -eq 0 ]; then
        if [ "${JSON}" -eq 1 ] || [ "${QUIET}" -eq 1 ]; then
            perform_self_install_v2
        else
            maybe_install_v2
        fi
    fi

    # =============================================================================
    # FLAG-FIRST ARGUMENT PARSING
    # =============================================================================
    while [ $# -gt 0 ]; do
        case "$1" in
            --reset|--force|--reinstall)
                FORCE_REINSTALL=1
                ;;
            --quiet|-q)
                QUIET=1
                ;;
            --json)
                JSON=1
                QUIET=1
                ;;
            --no-cloudflare)
                USE_CLOUDFLARE=0
                ;;
            version|-v)
                COMMAND="version"
                ;;
            version-check)
                COMMAND="version-check"
                ;;
            self-update)
                COMMAND="self-update"
                ;;
            self-uninstall)
                COMMAND="self-uninstall"
                ;;
            help|-h)
                COMMAND="help"
                ;;
            about)
                COMMAND="about"
                ;;
            domains)
                COMMAND="domains"
                ;;
            email)
                COMMAND="email"
                ;;
            nginx-conf)
                COMMAND="nginx-conf"
                ;;
            *)
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Unknown argument: $1" "bad_argument"
                else
                    error "Unknown argument: $1"
                    printf "Run '%s help' for usage.\n" "${APP_NAME}" >&2
                fi
                exit 1
                ;;
        esac
        shift
    done

    # =============================================================================
    # COMMAND DISPATCH
    # =============================================================================
    case "${COMMAND}" in
        version)
            if [ "${JSON}" -eq 1 ]; then
                output_json "version" "" "app" "${APP_NAME}" "version" "${VERSION}"
            else
                msg "${APP_NAME} version ${VERSION}"
            fi
            exit 0
            ;;

        version-check)
            version_check
            exit 0
            ;;

        self-update)
            self_update_v2
            exit 0
            ;;

        self-uninstall)
            self_uninstall
            exit 0
            ;;

        about)
            show_nginx_system_diagnostics
            exit 0
            ;;

        help)
            show_certbot_nginx_help
            exit 0
            ;;

        domains)
            show_domains
            exit 0
            ;;

        email)
            show_email
            exit 0
            ;;

        nginx-conf)
            check_root
            local domains
            domains=$(load_existing_domains)
            [ -z "$domains" ] && die "No domains found. Run full setup first."
            local main_domain
            main_domain=$(get_main_domain_from_file "$domains")
            [ -z "$main_domain" ] && die "Could not determine main domain."

            # 1.9.0: Backup before regenerating configs
            backup_nginx_sites_configs
            deploy_domain_nginx_configs "$domains" "$main_domain"
            info "✅ Nginx configs regenerated using main domain: ${main_domain}"
            exit 0
            ;;

        run)
            # Core setup flow - respects interactive vs non-interactive mode
            if [ "$TTY" -eq 1 ]; then
                run_interactive_setup
            else
                run_non_interactive_setup
            fi
            exit 0
            ;;

        *)
            die "Invalid command"
            ;;
    esac
}

# Call the main function
main_certbot_nginx_app "$@"