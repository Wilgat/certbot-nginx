# =============================================================================
# is_installed() - Robust installation check
# =============================================================================
#
# GENERAL PURPOSE:
# Checks whether the program is already installed, supporting both root
# and normal user installations with safe fallbacks.
#
# Please don't modify this code for root-only installed
# You can check [ "$(id -u)" -eq 0 ] before calling / excuting 
#   this function
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Designed to be reusable in other projects.
# =============================================================================

is_installed() {
    : "${GLOBAL_BIN:=/usr/local/bin}"
    : "${USER_BIN:=${HOME}/.local/bin}"
    : "${INSTALL_PATH:=${GLOBAL_BIN}/${APP_NAME}}"

    if [ "$(id -u)" -eq 0 ]; then
        IS_ROOT=1
        INSTALL_PATH="${GLOBAL_BIN}/${APP_NAME}"
    else
        IS_ROOT=0
        INSTALL_PATH="${USER_BIN}/${APP_NAME}"
    fi

    # Support explicit parameters or force flags
    if [ "${1:-}" = "--user" ] || [ "${FORCE_USER:-0}" -eq 1 ]; then
        [ -f "${USER_BIN}/${APP_NAME}" ] && [ -x "${USER_BIN}/${APP_NAME}" ] && return 0
        return 1
    elif [ "${1:-}" = "--global" ] || [ "${FORCE_GLOBAL:-0}" -eq 1 ]; then
        [ -f "${GLOBAL_BIN}/${APP_NAME}" ] && [ -x "${GLOBAL_BIN}/${APP_NAME}" ] && return 0
        return 1
    fi

    # Main logic
    if [ "$IS_ROOT" -eq 1 ]; then
        [ -f "${INSTALL_PATH}" ] && [ -x "${INSTALL_PATH}" ]
    else
        { [ -f "${GLOBAL_BIN}/${APP_NAME}" ] && [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; } ||
        { [ -f "${USER_BIN}/${APP_NAME}"   ] && [ -x "${USER_BIN}/${APP_NAME}"   ]; }
    fi
}

# =============================================================================
# get_installed_version() - Extract version from installed binary
# =============================================================================
#
# GENERAL PURPOSE:
# Safely reads the VERSION constant from the installed script.
# Used by version-check and self-update.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Designed to be reusable in other projects.
# =============================================================================
get_installed_version() {
    local bin_path
    if [ "$IS_ROOT" -eq 1 ] || [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; then
        bin_path="${GLOBAL_BIN}/${APP_NAME}"
    else
        bin_path="${USER_BIN}/${APP_NAME}"
    fi

    if [ -x "$bin_path" ]; then
        grep '^VERSION="' "$bin_path" 2>/dev/null | cut -d'"' -f2 || echo "unknown"
    else
        echo "not installed"
    fi
}

# =============================================================================
# version_check() - Compare local vs remote version + suggest install
# =============================================================================
#
# GENERAL PURPOSE:
# Fetches the latest version from GitHub raw and compares with installed one.
# If not installed and running in interactive terminal, it suggests installation.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Designed to be reusable in other projects.
# =============================================================================

version_check() {
    REMOTE_VERSION=$(curl -fsSL "${SCRIPT_URL}" 2>/dev/null | grep '^VERSION="' | cut -d'"' -f2 || echo "")

    if [ -z "$REMOTE_VERSION" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to fetch remote version" "network_error"
        else
            error "Failed to fetch remote version"
        fi
        return 1
    fi

    local local_version
    local_version=$(get_installed_version)

    if [ "${JSON}" -eq 1 ]; then
        output_json "version_check" \
            "local_version" "$local_version" \
            "remote_version" "$REMOTE_VERSION" \
            "is_latest" "$( [ "$local_version" = "$REMOTE_VERSION" ] && echo "true" || echo "false" )"
    else
        info "Checking latest version of ${APP_NAME}..."
        msg "Local version : ${local_version}"
        msg "Latest version: ${REMOTE_VERSION}"
        empty_line

        if [ "$local_version" = "$REMOTE_VERSION" ]; then
            success "You are running the latest version."
        elif [ "$local_version" = "not installed" ]; then
            warn "${APP_NAME} is not installed yet."
        else
            warn "A newer version is available (${REMOTE_VERSION})"
        fi
    fi
}

# =============================================================================
# self_update_v2() - Perform self-update to latest version
# =============================================================================
#
# GENERAL PURPOSE:
# Downloads and installs the latest version from GitHub.
# Respects --force and --quiet.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Designed to be reusable in other projects.
# =============================================================================

self_update_v2() {
    if [ "${JSON}" -eq 0 ]; then
        info "Starting self-update of ${APP_NAME}..."
    fi

    local REMOTE_VERSION
    REMOTE_VERSION=$(curl -fsSL "${SCRIPT_URL}" 2>/dev/null | grep '^VERSION="' | cut -d'"' -f2 || echo "")

    if [ -z "$REMOTE_VERSION" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to fetch latest version" "network_error"
        else
            error "Failed to fetch latest version"
        fi
        return 1
    fi

    local local_version
    local_version=$(get_installed_version)

    if [ "$local_version" = "$REMOTE_VERSION" ] && [ "${FORCE_REINSTALL}" -eq 0 ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "success" "message" "Already running the latest version (${REMOTE_VERSION})."
        else
            success "Already running the latest version (${REMOTE_VERSION})."
        fi
        return 0
    fi

    if [ "$local_version" != "$REMOTE_VERSION" ] && [ "${JSON}" -eq 0 ]; then
        info "Updating from ${local_version} → ${REMOTE_VERSION}"
    fi

    FORCE_REINSTALL=1
    perform_self_install_v2
}

# =============================================================================
# self_uninstall() - Remove ${APP_NAME} from the system
# =============================================================================
#
# GENERAL PURPOSE:
# Removes the installed ${APP_NAME} binary (global or user) and cleans up the PATH
# entry added by the installer in shell config files.
#
# Respects --force, --quiet, and --json.
# Works for both root and user installations.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Designed to be robust and reversible where possible.
# =============================================================================

self_uninstall() {
    if [ "${JSON}" -eq 0 ]; then
        info "Starting self-uninstall of ${APP_NAME}..."
    fi

    local bin_path=""
    local removed=0

    # Determine which installation to remove
    if [ "$(id -u)" -eq 0 ] || [ "${FORCE_GLOBAL:-0}" -eq 1 ]; then
        # Global (root) uninstall
        if [ -f "${GLOBAL_BIN}/${APP_NAME}" ]; then
            bin_path="${GLOBAL_BIN}/${APP_NAME}"
        fi
    else
        # User uninstall - prefer local, fallback to global if present
        if [ -f "${USER_BIN}/${APP_NAME}" ]; then
            bin_path="${USER_BIN}/${APP_NAME}"
        elif [ -f "${GLOBAL_BIN}/${APP_NAME}" ]; then
            bin_path="${GLOBAL_BIN}/${APP_NAME}"
            if [ "${JSON}" -eq 0 ]; then
                warn "Global installation found. Removing it (you may need sudo next time)."
            fi
        fi
    fi

    if [ -z "$bin_path" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "success" "message" "${APP_NAME} is not installed. Nothing to uninstall."
        else
            if [ "${FORCE_REINSTALL:-0}" -eq 1 ] || [ "${FORCE_USER:-0}" -eq 1 ] || [ "${FORCE_GLOBAL:-0}" -eq 1 ]; then
                warn "${APP_NAME} is not installed. Nothing to uninstall."
            else
                warn "${APP_NAME} is not installed."
            fi
        fi
        return 0
    fi

    # Confirm before removal (unless --force or non-interactive)
    if [ "${FORCE_REINSTALL:-0}" -eq 0 ] && [ -t 0 ] && [ -t 1 ] && [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ]; then
        printf "${YELLOW}This will remove: %s${NC}\n" "$bin_path"
        printf "Continue? (y/N): "
        read -r answer || true
        case "$answer" in
            [Yy]*|[Yy][Ee][Ss]*) ;;
            *) 
                if [ "${JSON}" -eq 1 ]; then
                    output_json "success" "message" "Uninstall cancelled by user."
                else
                    msg "Uninstall cancelled by user."
                fi
                return 0 
                ;;
        esac
    fi

    # Remove the binary
    if rm -f "$bin_path" 2>/dev/null; then
        removed=1
    else
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to remove ${bin_path} (permission denied?)" "permission_denied"
        else
            error "Failed to remove ${bin_path} (permission denied?)"
        fi
        return 1
    fi

    # Optional: clean up PATH entry in shell configs (user only)
    if [ "$(id -u)" -ne 0 ] && [ "$removed" -eq 1 ]; then
        local cleaned=0
        for config in "${HOME}/.bashrc" "${HOME}/.zshrc" "${HOME}/.config/fish/config.fish"; do
            if [ -f "$config" ]; then
                if sed -i.bak '/# Added by .* installer/d' "$config" 2>/dev/null && \
                sed -i.bak '/\.local\/bin:.*PATH/d' "$config" 2>/dev/null; then
                    cleaned=1
                fi
                rm -f "${config}.bak" 2>/dev/null || true
            fi
        done
        if [ "$cleaned" -eq 1 ] && [ "${JSON}" -eq 0 ]; then
            msg "→ Cleaned ${APP_NAME} PATH entries from shell config files"
            msg "→ You may want to restart your terminal"
        fi
    fi

    if [ "${JSON}" -eq 1 ]; then
        output_json "success" "message" "${APP_NAME} has been uninstalled."
    else
        success "${APP_NAME} has been uninstalled."
    fi
    return 0
}

# =============================================================================
# in_path() - Check if a directory is in $PATH
# =============================================================================
#
# GENERAL PURPOSE:
# Returns 0 if the given directory (default: INSTALL_DIR) is already in $PATH.
# POSIX-compatible using case statement (works in sh/dash/bash/zsh).
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# Designed to be reusable in other projects.
# =============================================================================

in_path() {
    case ":${PATH}:" in
        *:"${1:-$USER_BIN}":*) return 0 ;;
        *) return 1 ;;
    esac
}

# =============================================================================
# add_to_shell_path() - Multi-shell PATH support (bash + zsh + fish)
# =============================================================================
#
# GENERAL PURPOSE:
# Adds ~/.local/bin to the user's shell configuration for bash, zsh, and fish.
# Works even if the user is currently using a different shell.
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# Designed to be reusable in other projects.
# =============================================================================

add_to_shell_path() {
    local added=0
    local shell_config="N/A"

    # Bash
    local bashrc="${HOME}/.bashrc"
    if [ -f "$bashrc" ]; then
        if [ "$shell_config" = "N/A" ]; then
            shell_config="${bashrc}"
        else
            shell_config="${shell_config} ${bashrc}"
        fi
        if ! grep -qF 'export PATH="$HOME/.local/bin:$PATH"' "$bashrc" 2>/dev/null; then
            printf "\n# Added by %s installer (%s)\n" "$APP_NAME" "$VERSION" >> "$bashrc"
            printf 'export PATH="$HOME/.local/bin:$PATH"\n' >> "$bashrc"
            added=1
            if [ "${JSON}" -eq 0 ]; then
                msg "→ Added ~/.local/bin to PATH for bash"
            fi
        fi
    fi

    # Zsh
    local zshrc="${HOME}/.zshrc"
    if [ -f "$zshrc" ]; then
        if [ "$shell_config" = "N/A" ]; then
            shell_config="${zshrc}"
        else
            shell_config="${shell_config} ${zshrc}"
        fi
        if ! grep -qF 'export PATH="$HOME/.local/bin:$PATH"' "$zshrc" 2>/dev/null; then
            printf "\n# Added by %s installer (%s)\n" "$APP_NAME" "$VERSION" >> "$zshrc"
            printf 'export PATH="$HOME/.local/bin:$PATH"\n' >> "$zshrc"
            added=1
            if [ "${JSON}" -eq 0 ]; then
                msg "→ Added ~/.local/bin to PATH for zsh"
            fi
        fi
    fi

    # Fish
    local fish_config="${HOME}/.config/fish/config.fish"
    if [ -d "${HOME}/.config/fish" ] || mkdir -p "${HOME}/.config/fish" 2>/dev/null; then
        if [ "$shell_config" = "N/A" ]; then
            shell_config="${fish_config}"
        else
            shell_config="${shell_config} ${fish_config}"
        fi
        if [ -f "$fish_config" ] && grep -qF 'set -gx PATH $HOME/.local/bin $PATH' "$fish_config" 2>/dev/null; then
            : # already present
        else
            printf "\n# Added by %s installer (%s)\n" "$APP_NAME" "$VERSION" >> "$fish_config"
            printf 'set -gx PATH $HOME/.local/bin $PATH\n' >> "$fish_config"
            added=1
            if [ "${JSON}" -eq 0 ]; then
                msg "→ Added ~/.local/bin to PATH for fish shell"
            fi
        fi
    fi

    if [ "$added" -eq 1 ] && [ "${JSON}" -eq 0 ]; then
        msg "→ Restart your terminal or run: source ${shell_config}"
    fi
}

# =============================================================================
# SELF-INSTALL LOGIC (root-only) - UPDATED TO v2 (April 2026)
# =============================================================================
#
# CRITICAL DEFENSIVE FUNCTION - DO NOT SIMPLIFY, REMOVE, OR REFACTOR
#
# New in v2 (perform_self_install_v2):
#   1. If environment variable CHECKSUM=<sha256> is set (e.g. exported by user or CI),
#      the script will:
#        • Download the script from ${SCRIPT_URL}
#        • Verify the downloaded content against the provided CHECKSUM using sha256sum
#        • Only proceed with installation if the checksum matches exactly
#        • This allows users/CI to pin a known-good version and protect against
#          MITM, compromised GitHub raw, or network tampering.
#
#   2. If CHECKSUM is NOT set (normal interactive/one-liner usage):
#        • First attempt: curl ${SCRIPT_URL} (the script itself)
#        • Second attempt: also fetch ${SCRIPT_URL}.sha256 (if HTTP 200)
#        • If the .sha256 file exists and is valid, verify the downloaded script
#          with "sha256sum -c"
#        • If verification fails → die with clear error (incorrect checksum)
#        • If no .sha256 file or verification skipped → proceed (backward compatible)
#
# Why this v2 protection is needed (Defensive Reasoning):
#   • The classic `curl | sh` pattern is convenient but inherently risky.
#   • GitHub raw content can be tampered with via account compromise, supply-chain attack,
#     or transient network interception.
#   • Providing both an explicit CHECKSUM env var and automatic .sha256 lookup
#     significantly reduces the attack surface for one-command installs.
#   • Maintains full backward compatibility for users who do not provide CHECKSUM.
#   • Aligns with CIAO-Lite "Caution" and "Over-protect" principles.
#   • Prevents silent installation of malicious code — fail loudly on checksum mismatch.
#
# Updated from previous version:
#   • Old: perform_self_install() performed blind download + move.
#   • New: perform_self_install_v2() adds layered checksum verification while keeping
#     the rest of the installation logic (temp file, permissions, PATH handling) identical.
#   • The function name was deliberately changed to perform_self_install_v2 to clearly
#     signal the security upgrade. Old name is preserved in comments for reference.
#   • All other self-update / self-uninstall logic continues to call the v2 version.
#
# !!! THIS IS THE SINGLE SOURCE OF TRUTH FOR SELF-INSTALLATION !!!
# !!! DO NOT RENAME BACK, DO NOT MERGE WITH OTHER FUNCTIONS !!!
# !!! ALWAYS CALL perform_self_install_v2() FOR NEW INSTALLS !!!
# Shebang remains #!/bin/sh - defensive and portable.
# Repeated safe defaults and heavy comments are intentional.
#
# Aligned with https://github.com/Wilgat/ciao
# Last aligned: April 2026
# =============================================================================

perform_self_install_v2() {
    : "${GLOBAL_BIN:=/usr/local/bin}"
    : "${USER_BIN:=${HOME}/.local/bin}"
    : "${INSTALL_PATH:=${GLOBAL_BIN}/${APP_NAME}}"

    if [ "$(id -u)" -eq 0 ]; then
        IS_ROOT=1
        INSTALL_PATH="${GLOBAL_BIN}/${APP_NAME}"
    else
        IS_ROOT=0
        INSTALL_PATH="${USER_BIN}/${APP_NAME}"
    fi

    if [ -z "$REMOTE_VERSION" ]; then
        REMOTE_VERSION=${VERSION}
    fi

    if [ "${JSON}" -eq 0 ]; then
        info "Starting installation of ${APP_NAME} ${REMOTE_VERSION}..."
    fi

    if is_installed && [ "${FORCE_REINSTALL}" -eq 0 ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "success" "message" "${APP_NAME} is already installed."
        else
            success "${APP_NAME} is already installed. Use --force to override."
        fi
        return 0
    fi

    # Create correct target directory (root vs user)
    if [ "$IS_ROOT" -eq 1 ]; then
        if ! mkdir -p "${GLOBAL_BIN}" 2>/dev/null; then
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Failed to create ${GLOBAL_BIN}" "io_error"
            else
                error "Failed to create ${GLOBAL_BIN}"
            fi
            return 1
        fi
    else
        if ! mkdir -p "${USER_BIN}" 2>/dev/null; then
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Failed to create ${USER_BIN}" "io_error"
            else
                error "Failed to create ${USER_BIN}"
            fi
            return 1
        fi
    fi

    local tmp_file
    tmp_file=$(mktemp -t "${APP_NAME}.XXXXXX") || {
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to create temporary file" "io_error"
        else
            error "Failed to create temporary file"
        fi
        return 1
    }

    if [ "${JSON}" -eq 0 ]; then
        info "Downloading ${APP_NAME} from GitHub..."
    fi

    # =============================================================================
    # CHECKSUM VERIFICATION LAYER (v2 security upgrade)
    # =============================================================================
    local downloaded_checksum_ok=0

    if [ -n "${CHECKSUM:-}" ]; then
        # Explicit CHECKSUM provided by user/CI → strict verification
        if [ "${JSON}" -eq 0 ]; then
            info "Verifying download against provided CHECKSUM..."
        fi

        if command -v curl >/dev/null 2>&1; then
            curl -fsSL "${SCRIPT_URL}" -o "${tmp_file}" || {
                rm -f "${tmp_file}"
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Download failed (curl)" "network_error"
                else
                    error "Download failed (curl)"
                fi
                return 1
            }
        elif command -v wget >/dev/null 2>&1; then
            wget -qO "${tmp_file}" "${SCRIPT_URL}" || {
                rm -f "${tmp_file}"
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Download failed (wget)" "network_error"
                else
                    error "Download failed (wget)"
                fi
                return 1
            }
        else
            rm -f "${tmp_file}"
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Neither curl nor wget found" "missing_dependency"
            else
                error "Neither curl nor wget found"
            fi
            return 1
        fi

        # Verify provided CHECKSUM
        if printf '%s  %s\n' "${CHECKSUM}" "${tmp_file}" | sha256sum -c - >/dev/null 2>&1; then
            downloaded_checksum_ok=1
            if [ "${JSON}" -eq 0 ]; then
                success "Checksum verification passed (user-provided CHECKSUM)."
            fi
        else
            rm -f "${tmp_file}"
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Checksum verification failed (provided CHECKSUM does not match)" "checksum_mismatch"
            else
                die "Checksum verification failed. The downloaded file does not match the provided CHECKSUM. Installation aborted for security."
            fi
            return 1
        fi

    else
        # No explicit CHECKSUM → try automatic .sha256 file (best-effort)
        if [ "${JSON}" -eq 0 ]; then
            info "No CHECKSUM provided → attempting automatic verification via ${SCRIPT_URL}.sha256"
        fi

        if command -v curl >/dev/null 2>&1; then
            # Primary download
            curl -fsSL "${SCRIPT_URL}" -o "${tmp_file}" || {
                rm -f "${tmp_file}"
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Download failed (curl)" "network_error"
                else
                    error "Download failed (curl)"
                fi
                return 1
            }

            # Try to fetch .sha256 sidecar
            local sha_file
            sha_file=$(mktemp -t "${APP_NAME}.sha256.XXXXXX") || {
                rm -f "${tmp_file}"
                return 1
            }

            if curl -fsSL -w "%{http_code}" "${SCRIPT_URL}.sha256" -o "${sha_file}" 2>/dev/null | grep -q "^200"; then
                if sha256sum -c "${sha_file}" --status 2>/dev/null < "${tmp_file}"; then
                    downloaded_checksum_ok=1
                    if [ "${JSON}" -eq 0 ]; then
                        success "Automatic checksum verification passed (${SCRIPT_URL}.sha256)."
                    fi
                else
                    rm -f "${tmp_file}" "${sha_file}"
                    if [ "${JSON}" -eq 1 ]; then
                        output_json_error "Automatic checksum verification failed" "checksum_mismatch"
                    else
                        die "Checksum verification failed (mismatch with ${SCRIPT_URL}.sha256). Installation aborted for security."
                    fi
                    return 1
                fi
            else
                # No .sha256 available → proceed without verification (backward compatible)
                if [ "${JSON}" -eq 0 ]; then
                    warn "No .sha256 file found at ${SCRIPT_URL}.sha256 → continuing without automatic verification."
                fi
            fi
            rm -f "${sha_file}" 2>/dev/null || true

        elif command -v wget >/dev/null 2>&1; then
            # Similar logic for wget (kept minimal and defensive)
            wget -qO "${tmp_file}" "${SCRIPT_URL}" || {
                rm -f "${tmp_file}"
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Download failed (wget)" "network_error"
                else
                    error "Download failed (wget)"
                fi
                return 1
            }

            local sha_file
            sha_file=$(mktemp -t "${APP_NAME}.sha256.XXXXXX") || {
                rm -f "${tmp_file}"
                return 1
            }

            if wget -q --server-response "${SCRIPT_URL}.sha256" -O "${sha_file}" 2>&1 | grep -q "HTTP/1.1 200"; then
                if sha256sum -c "${sha_file}" --status 2>/dev/null < "${tmp_file}"; then
                    downloaded_checksum_ok=1
                    if [ "${JSON}" -eq 0 ]; then
                        success "Automatic checksum verification passed."
                    fi
                else
                    rm -f "${tmp_file}" "${sha_file}"
                    if [ "${JSON}" -eq 1 ]; then
                        output_json_error "Automatic checksum verification failed" "checksum_mismatch"
                    else
                        die "Checksum verification failed. Installation aborted for security."
                    fi
                    return 1
                fi
            else
                if [ "${JSON}" -eq 0 ]; then
                    warn "No .sha256 file found → continuing without automatic verification."
                fi
            fi
            rm -f "${sha_file}" 2>/dev/null || true
        else
            rm -f "${tmp_file}"
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Neither curl nor wget found" "missing_dependency"
            else
                error "Neither curl nor wget found"
            fi
            return 1
        fi
    fi

    # Final safety: if we reached here without explicit failure, file is in tmp_file
    chmod +x "${tmp_file}" 2>/dev/null || true

    rm -f "${INSTALL_PATH}" 2>/dev/null
    if ! mv "${tmp_file}" "${INSTALL_PATH}" 2>/dev/null; then
        rm -f "${tmp_file}"
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to move to ${INSTALL_PATH}" "io_error"
        else
            error "Failed to move to ${INSTALL_PATH}"
        fi
        return 1
    fi

    # Add ~/.local/bin to PATH for normal user installs
    if [ "$IS_ROOT" -eq 0 ]; then
        add_to_shell_path
    fi
    
    if [ "${JSON}" -eq 1 ]; then
        output_json "success" "message" "${APP_NAME} ${REMOTE_VERSION} successfully installed to ${INSTALL_PATH}"
    else
        success "${APP_NAME} ${REMOTE_VERSION} successfully installed to ${INSTALL_PATH}"
        if [ "${downloaded_checksum_ok}" -eq 1 ]; then
            success "✓ Download was cryptographically verified."
        fi
    fi
    return 0
}

# =============================================================================
# maybe_install_v2() - Friendly installation prompt
# =============================================================================
#
# Respects both --quiet and --json modes.
# In JSON mode we skip the interactive prompt entirely.
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# Designed to be reusable in other projects.
# =============================================================================

maybe_install_v2() {
    if is_installed && [ "${FORCE_REINSTALL}" -eq 0 ]; then
        return 0
    fi

    # In JSON mode or quiet mode we do not show interactive prompts
    if [ "${JSON}" -eq 1 ] || [ "${QUIET}" -eq 1 ]; then
        return 0
    fi

    empty_line
    msg "Note: '${APP_NAME}' is not installed yet."
    msg "     Version: ${VERSION}"
    empty_line
    msg "Recommended installation command:"
    empty_line

    if [ "$IS_ROOT" -eq 1 ]; then
        msg "     sudo curl -fsSL ${SCRIPT_URL} | sudo ${SH}"
    else
        msg "     curl -fsSL ${SCRIPT_URL} | ${SH}"
    fi
    empty_line

    local should_install=false

    if [ -t 0 ] && [ -t 1 ]; then
        msg_n "     Install now? (y/N): "     # No newline at the end
        read -r answer || true
        case "$answer" in
            [Yy]*|[Yy][Ee][Ss]*) should_install=true ;;
            *) 
                msg "Installation skipped by user."
                return 0 
                ;;
        esac
    else
        msg "Non-interactive mode detected → installing automatically..."
        should_install=true
    fi

    if [ "$should_install" = "true" ]; then
        perform_self_install_v2
        exit 0
    fi
}

# =============================================================================
# detect_nginx_platform_paths() - Detect OS-specific nginx paths
# =============================================================================
#
# Purpose:
#   Detects the correct nginx configuration root and style for the current OS.
#   Currently prepared for future use — not yet called in main flow.
#
# Supported Platforms:
#   • Debian/Ubuntu → /etc/nginx + sites-available
#   • RHEL/Rocky    → /etc/nginx + conf.d (planned)
#   • Alpine        → /etc/nginx
#   • macOS Homebrew (Intel)   → /usr/local/etc/nginx
#   • macOS Homebrew (Apple Silicon) → /opt/homebrew/etc/nginx
#   • MacPorts      → /opt/local/etc/nginx
#
# Defensive Design:
#   • Uses safe defaults so current Linux behavior is unchanged.
#   • Loud intention comment to prevent future AI from removing it.
#   • Can be called early in run_interactive_setup() when we expand support.
#
# Current Status (1.16.0):
#   This function exists for planning and future-proofing only.
#   It will be activated when we implement full multi-OS nginx.conf adaptation.
#
# !!! THIS FUNCTION MUST NOT BE REMOVED !!!
# !!! IT DOCUMENTS OUR CLEAR INTENTION FOR CROSS-PLATFORM SUPPORT !!!
# !!! FUTURE AI ASSISTANTS MUST RESPECT THIS PLAN !!!
# =============================================================================

detect_nginx_platform_paths() {
    local os_type
    os_type=$(uname -s 2>/dev/null | tr '[:upper:]' '[:lower:]')

    case "$os_type" in
        darwin*)  # macOS
            if [ -d "/opt/homebrew/etc/nginx" ]; then
                NGINX_CONF_ROOT="/opt/homebrew/etc/nginx"
                NGINX_PLATFORM="homebrew-arm"
            elif [ -d "/usr/local/etc/nginx" ]; then
                NGINX_CONF_ROOT="/usr/local/etc/nginx"
                NGINX_PLATFORM="homebrew-intel"
            elif [ -d "/opt/local/etc/nginx" ]; then
                NGINX_CONF_ROOT="/opt/local/etc/nginx"
                NGINX_PLATFORM="macports"
            fi
            ;;
        linux*)
            if command -v apt-get >/dev/null 2>&1; then
                NGINX_PLATFORM="debian"
            elif command -v dnf >/dev/null 2>&1 || command -v yum >/dev/null 2>&1; then
                NGINX_PLATFORM="rhel"
            elif command -v apk >/dev/null 2>&1; then
                NGINX_PLATFORM="alpine"
            fi
            ;;
    esac

    # Re-apply paths based on detected root
    NGINX_SITES_AVAILABLE="${NGINX_CONF_ROOT}/sites-available"
    NGINX_SITES_ENABLED="${NGINX_CONF_ROOT}/sites-enabled"
    NGINX_CONF_D="${NGINX_CONF_ROOT}/conf.d"

    if [ "${JSON}" -eq 0 ] && [ "${QUIET}" -eq 0 ]; then
        info "Detected nginx platform: ${NGINX_PLATFORM} (root: ${NGINX_CONF_ROOT})"
    fi
}

