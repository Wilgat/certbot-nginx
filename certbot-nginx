#
# !!! THIS FUNCTION IS PART OF THE DEFENSIVE DOMAIN PERSISTENCE CHAIN !!!
# !!! DO NOT MODIFY ITS BEHAVIOR OR REMOVE THE ENSURE CALL !!!
# =============================================================================

save_domains_to_file() {
    local domain_list="$1"

    ensure_letsencrypt_structure

    # === DEFENSIVE SANITY CHECK ===
    if echo "$domain_list" | grep -qE '(\[INFO\]|\[OK\]|\[WARN\]|\[ERROR\]|\u2705|===|Current domains|Primary domain accepted)'; then
        die "BUG: Domains list contains UI output. This should never happen. Please report this issue."
    fi

    # Save domains one per line (clean)
    echo "$domain_list" | tr ' ' '\n' | sed '/^$/d' > "$DOMAINS_FILE"
    chmod 644 "$DOMAINS_FILE"

    # Respect quiet and json modes
    if [ "${JSON}" -eq 0 ] && [ "${QUIET}" -eq 0 ]; then
        info "Domains saved to ${DOMAINS_FILE}"
    fi
}

# =============================================================================
# ask_and_confirm_domains() - Interactive Domain Confirmation & Addition
# =============================================================================
#
# CRITICAL INTERACTIVE FUNCTION - DO NOT SIMPLIFY OR REFACTOR
#
# Purpose:
#   This function is called AFTER the user has explicitly chosen the main/primary
#   domain via get_main_domain(). 
#
#   Its ONLY job is to let the user ADD additional domains (SANs).
#   It does NOT decide or change the main domain.
#
# Key Rules (Must Follow):
#   • The main domain (passed as first item) must remain at the front.
#   • User can only append extra domains.
#   • Must respect --quiet and --json modes (do nothing in those modes).
#   • Must use central output functions (display_current_domains, msg, info, etc.).
#   • After user finishes adding domains, the final list is returned with main
#     domain still at the front (re-arrangement happens in run_interactive_setup).
#   • Prints ALL output to stderr so it is never captured by command substitution.
#
# Design Intent:
#   Main domain = User decision (get_main_domain)
#   Extra domains = User confirmation & addition (this function)
#
# !!! THIS FUNCTION IS PART OF THE "MAIN DOMAIN IS CHOSEN BY USER" RULE !!!
# !!! DO NOT ATTEMPT TO DETERMINE MAIN DOMAIN FROM LIST POSITION HERE !!!
# =============================================================================

ask_and_confirm_domains() {
    if [ "$TTY" = "0" ]; then
        echo "$1"   # Return original list in non-interactive mode
        return 0
    fi

    local domains="$1"

    while true; do
        display_current_domains "$domains"

        read -rp "Do you want to add more domains? (yes/no): " add_more
        add_more=$(echo "$add_more" | tr '[:upper:]' '[:lower:]')

        if [ "$add_more" = "no" ] || [ "$add_more" = "n" ]; then
            ui_info "✅ Domains confirmed."
            echo "$domains"
            return 0
        fi

        ui_info "Enter additional domains one by one (press Enter on empty line when done):"

        while true; do
            read -rp "  Domain: " new_domain
            [ -z "$new_domain" ] && break

            # Clean input
            new_domain=$(echo "$new_domain" | tr -dc 'a-zA-Z0-9.-' | tr '[:upper:]' '[:lower:]')
            [ -z "$new_domain" ] && continue

            # Avoid duplicates
            local found=0
            for existing in $domains; do
                if [ "$existing" = "$new_domain" ]; then
                    found=1
                    ui_warn "Domain ${new_domain} is already in the list."
                    break
                fi
            done

            if [ $found -eq 0 ]; then
                domains="$domains $new_domain"
                ui_info "Added: ${new_domain}"
            fi
        done

        # Clean and deduplicate list (but do not change order of main domain)
        domains=$(echo "$domains" | tr ' ' '\n' | sort -u | tr '\n' ' ' | sed 's/^ *//;s/ *$//')
    done
}

# =============================================================================
# install_certbot() - Install Certbot (Cross-Platform Support)
# =============================================================================
#
# CRITICAL FUNCTION - PART OF THE STRICT INSTALLATION SEQUENCE
#
# Purpose:
#   Installs the base `certbot` package/tool **without** any web server plugins.
#   This script uses `certbot certonly --standalone`, so only the core client is needed.
#
# Alignment with CRITICAL REQUIREMENTS (Header):
#   • Step 1: Install Certbot without plugin configuration
#   • Full sequence: Install packages → Stop nginx early → Handle email & domains
#     independently → Apply certificates (standalone) → Setup Nginx config
#
# Recent Improvement (April 2026 - Idempotency Enhancement):
#   • Strengthened early check: now verifies both `command -v certbot` AND that
#     the binary is executable (`[ -x "$(command -v certbot)" ]`).
#   • If certbot already exists, the function returns immediately with clear
#     status message (supports --json and normal mode).
#   • This prevents unnecessary package manager calls on repeated runs and
#     reduces noise in automation / reinstall scenarios.
#   • Maintains full defensive style while improving Caution and Anti-fragility.
#
# Platform Support Strategy (2026 Defensive Approach):
#   1. Linux with snapd (Ubuntu, Debian, Fedora, CentOS, Rocky, etc.) → snap (RECOMMENDED)
#      • Official EFF preference: always latest version, auto-updates.
#   2. Debian/Ubuntu fallback → apt (if snap unavailable)
#   3. Alpine Linux → apk
#   4. macOS → Homebrew (brew)
#   5. Git Bash / MSYS2 / Windows native → Not fully supported natively.
#      Warn user and suggest WSL2 or manual pip install.
#
# Why This Order?
#   • Snap provides the most reliable, up-to-date Certbot with minimal maintenance.
#   • Distribution packages (apt/dnf/apk) can lag behind Let's Encrypt requirements.
#   • Homebrew is the standard and cleanest method on macOS.
#   • Git Bash has poor native support for Certbot (no official binary, path issues).
#
# Defensive Design Rules:
#   • Detect platform using `uname` and common package managers (idempotent).
#   • Check if certbot is already available before installing.
#   • Never mix installation methods (e.g., avoid installing both snap and apt).
#   • All output goes through central `info()` / `warn()` / `die()` functions.
#   • Fail with clear, actionable messages for unsupported platforms.
#   • No configuration or certbot commands are run here.
#
# Important Notes:
#   • Snap installation may require `snapd` to be installed first.
#   • On macOS, Homebrew must be pre-installed by the user.
#   • After installation on Linux, we often create a symlink for `/usr/bin/certbot`.
#   • Git Bash / MSYS2 users are encouraged to use WSL2 for full compatibility.
#
# !!! THIS FUNCTION MUST REMAIN AS THE VERY FIRST INSTALL STEP !!!
# !!! DO NOT INSTALL CERTBOT PLUGINS HERE !!!
# !!! DO NOT COMBINE WITH install_nginx() !!!
# !!! UPDATE THIS FUNCTION WHEN NEW OFFICIAL METHODS APPEAR !!!
# =============================================================================

install_certbot() {
    if command -v certbot >/dev/null 2>&1 && [ -x "$(command -v certbot)" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "status" "certbot already installed" "path" "$(command -v certbot)"
        else
            info "certbot is already installed."
        fi
        return 0
    fi

    info "certbot not found → attempting platform-specific installation..."

    # Detect platform
    local OS
    OS=$(uname -s 2>/dev/null | tr '[:upper:]' '[:lower:]')

    case "$OS" in
        linux*)
            # Try snap first (official recommended method in 2026)
            if command -v snap >/dev/null 2>&1; then
                info "snap detected → installing certbot via snap (recommended)..."
                snap install --classic certbot || warn "Snap install failed, trying fallback..."

                # Create symlink for easy access (common practice)
                if [ -f "/snap/bin/certbot" ] && [ ! -f "/usr/bin/certbot" ]; then
                    ln -sf /snap/bin/certbot /usr/bin/certbot 2>/dev/null || true
                fi

                if command -v certbot >/dev/null 2>&1; then
                    info "certbot installed successfully via snap."
                    return 0
                fi
            fi

            # Alpine Linux (apk)
            if command -v apk >/dev/null 2>&1; then
                info "Alpine Linux detected → installing via apk..."
                apk add --no-cache certbot || die "Failed to install certbot via apk."
                info "certbot installed successfully via apk."
                return 0
            fi

            # Debian/Ubuntu fallback (apt)
            if command -v apt-get >/dev/null 2>&1; then
                info "Debian/Ubuntu detected → installing via apt-get..."
                apt-get update -qq || warn "apt-get update failed (continuing)"
                apt-get install -y certbot || die "Failed to install certbot via apt."
                info "certbot installed successfully via apt."
                return 0
            fi

            # Other Linux (e.g. Fedora, CentOS) - could add dnf/yum later if needed
            die "Linux detected but no supported package manager (snap/apk/apt) found. Please install certbot manually."
            ;;

        darwin*)  # macOS
            if command -v brew >/dev/null 2>&1; then
                info "macOS detected → installing certbot via Homebrew..."
                brew install certbot || die "Failed to install certbot via brew."
                info "certbot installed successfully via Homebrew."
                return 0
            else
                die "Homebrew not found on macOS. Please install Homebrew first[](https://brew.sh/) then rerun."
            fi
            ;;

        *)
            # Git Bash / MSYS2 / Windows / unknown
            if [ -n "$MSYSTEM" ] || echo "$OS" | grep -q "mingw"; then
                warn "Git Bash / MSYS2 detected."
                die "Certbot is not well supported in Git Bash. Recommended: Use WSL2 (Ubuntu) or install manually via Python pip."
            else
                die "Unsupported operating system: ${OS}. This script currently supports Linux (snap/apk/apt), macOS (Homebrew), and warns on Git Bash."
            fi
            ;;
    esac
}

# =============================================================================
# get_or_set_email() - Handle Let's Encrypt Email (Independent & Early)
# =============================================================================
#
# CRITICAL FUNCTION - PART OF THE "EMAIL AND DOMAIN LIST HANDLING MUST BE DONE FIRST" RULE
#
# Purpose:
#   This function is responsible for retrieving or interactively collecting
#   the email address used for Let's Encrypt registration and expiration notifications.
#
#   According to the CRITICAL REQUIREMENTS defined in the script header:
#     • Email handling MUST be done FIRST and INDEPENDENTLY — before ANY
#       Certbot installation steps, certificate requests, or Nginx configuration.
#     • The email is saved persistently in /etc/letsencrypt/email.conf
#     • This value is reused on future runs and by Certbot renewals.
#
# Why Independent & Early?
#   • Let's Encrypt requires a valid email during certificate issuance.
#   • Certbot uses this email for important notifications (certificate expiration,
#     renewal failures, rate limit warnings, etc.).
#   • By handling email separately from domains and before any Certbot command,
#     we strictly follow the defensive sequence:
#       Install packages → Stop nginx → Handle email → Handle domains → Get certs → Configure nginx
#
# Defensive Design Rules Applied Here:
#   • ALWAYS call ensure_letsencrypt_structure() first — never assume the directory
#     or email.conf file exists (fresh systems, interrupted installs, manual deletions).
#   • If the file exists and contains a valid email, reuse it silently (idempotent).
#   • In non-interactive / TTY=0 mode: fail fast with clear error (forces interactive run).
#   • Input validation: email cannot be empty.
#   • File permissions: 600 (owner read/write only) for security.
#   • All output goes through the central output system (info/warn/die).
#
# Behavior:
#   • Interactive (TTY): Prompts user if no saved email found.
#   • Non-interactive: Dies with error — email must be set interactively first.
#   • Returns the email address (so it can be used immediately by apply_letsencrypt_standalone).
#
# This function is intentionally simple and loud — repetition and clear comments
# ensure future maintainers (and AI assistants) do not accidentally move or combine
# this step with domain handling or Certbot calls.
#
# !!! THIS FUNCTION MUST REMAIN EARLY IN run_interactive_setup() !!!
# !!! DO NOT COMBINE WITH DOMAIN LOGIC !!!
# !!! DO NOT REMOVE THE ENSURE_ LETSENCRYPT_STRUCTURE CALL !!!
# =============================================================================

get_or_set_email() {
    ensure_letsencrypt_structure

    # Check for existing saved email
    if [ -f "$EMAIL_FILE" ] && [ -s "$EMAIL_FILE" ]; then
        local email
        email=$(tr -d ' \t\n\r' < "$EMAIL_FILE")

        if [ -n "$email" ]; then
            ui_info "Using saved Let's Encrypt email: ${email}"
            echo "$email"
            return 0
        fi
    fi

    # Non-interactive mode: email must already be configured
    if [ "$TTY" = "0" ]; then
        die "No email configured in ${EMAIL_FILE}. Please run the script interactively first (sudo ${APP_NAME})."
    fi

    # Interactive email collection
    local email=""
    while true; do
        read -rp "Enter your email address for Let's Encrypt notifications: " email

        # Basic cleaning
        email=$(echo "$email" | tr -d ' \t\n\r')

        if [ -n "$email" ]; then
            # Optional: could add basic email format validation here in future
            break
        fi

        ui_warn "Email address cannot be empty."
    done

    # Save email with strict permissions
    echo "$email" > "$EMAIL_FILE"
    chmod 600 "$EMAIL_FILE"

    ui_info "Email address saved to ${EMAIL_FILE}"
    echo "$email"
}

# =============================================================================
# stop_nginx_early() - Stop Nginx and Port 80 Before Any Certificate Operation
# =============================================================================
#
# CRITICAL FUNCTION - PART OF THE STRICT INSTALLATION SEQUENCE
#
# Purpose:
#   This function MUST be called early (right after package installation)
#   to ensure nginx is completely stopped before Certbot --standalone runs.
#
# Alignment with CRITICAL REQUIREMENTS (Header):
#   • Step 3: Stop Nginx service early
#   • Prevents nginx from ever running with empty or broken configuration
#   • Allows Certbot --standalone to bind cleanly to port 80
#   • Follows the internal (Certbot) → external (Nginx) model
#
# Why This Is Non-Negotiable (Defensive Reasoning):
#   • An empty ${NGINX_CONF_ROOT}/sites-enabled/default or partial config can cause
#     nginx to fail to start or behave unpredictably.
#   • Certbot --standalone needs exclusive access to port 80 for HTTP-01 challenges.
#   • Starting nginx too early (or letting it stay running) is one of the most
#     common failure modes with Certbot + Nginx setups.
#   • Previous Grok instances repeatedly tried to combine or soften this step —
#     this loud comment block exists to prevent that.
#
# Actions Performed:
#   • systemctl stop nginx (graceful, respects systemd)
#   • fuser -k 80/tcp (aggressive kill of anything listening on port 80)
#   • Short sleep to allow ports to fully release
#
# !!! THIS FUNCTION MUST REMAIN EARLY IN BOTH INTERACTIVE AND NON-INTERACTIVE FLOWS !!!
# !!! DO NOT REMOVE THE fuser KILL OR SOFTEN THIS BEHAVIOR !!!
# !!! DO NOT START NGINX BEFORE CERTIFICATES ARE APPLIED !!!
# =============================================================================

stop_nginx_early() {
    info "Stopping nginx and any process listening on port 80..."

    sudo systemctl stop nginx 2>/dev/null || true

    fuser -k 80/tcp 2>/dev/null || true

    sleep 2

    info "Nginx and port 80 cleared."
}

# =============================================================================
# apply_certificates() - Request Let's Encrypt Certificate Using --standalone
# =============================================================================
#
# CRITICAL FUNCTION - STRICT SEQUENCE ENFORCEMENT
#
# Purpose:
#   Requests a single certificate for the main domain (as Common Name)
#   plus all additional domains as Subject Alternative Names (SANs).
#
# Alignment with CRITICAL REQUIREMENTS:
#   • Step 5: Ensure nginx is stopped → then run Certbot using the user-chosen main domain
#   • Step 6: ONLY AFTER certificates are successfully applied: setup Nginx config
#   • Uses --standalone (not --nginx plugin) to avoid configuration conflicts
#
# Key Rules Enforced:
#   • Must run AFTER stop_nginx_early()
#   • Uses the user-chosen main domain for the certificate directory path
#   • All domains share ONE certificate (main_domain + SANs)
#   • Persistent storage under /etc/letsencrypt/live/${main_domain}/
#   • Defensive post-check: verify fullchain.pem actually exists
#
# Why --standalone?
#   It provides the cleanest separation between Certbot (certificate provider)
#   and Nginx (external web server). This avoids many common plugin-related failures.
#
# Defensive Design:
#   • Always call ensure_letsencrypt_structure() first
#   • Clear error handling via die()
#   • Explicit success message
#   • No assumption that directories or files exist beforehand
#
# !!! THIS FUNCTION (OR apply_letsencrypt_standalone) MUST RUN BEFORE deploy_domain_nginx_configs() !!!
# !!! DO NOT MOVE CERTBOT CALLS AFTER NGINX CONFIGURATION !!!
# !!! DO NOT USE --nginx PLUGIN IN THE MAIN FLOW !!!
# =============================================================================

apply_certificates() {
    local domains="$1"
    local email="$2"
    local main_domain="$3"

    ensure_letsencrypt_structure

    # Defensive input validation
    [ -z "$domains" ]     && die "No domains provided to apply_certificates()"
    [ -z "$email" ]       && die "No email provided to apply_certificates()"
    [ -z "$main_domain" ] && die "No main domain provided to apply_certificates()"

    local cert_domains_comma
    cert_domains_comma=$(echo "$domains" | tr ' ' ',')

    info "Requesting Let's Encrypt certificate for ${main_domain} (and SANs) using --standalone..."

    certbot certonly --standalone \
        --email "$email" \
        --agree-tos \
        --non-interactive \
        --domains "$cert_domains_comma" || die "Certbot failed to obtain certificates."

    # Critical verification step
    if [ ! -f "/etc/letsencrypt/live/${main_domain}/fullchain.pem" ]; then
        die "Certificate files not found for main domain: ${main_domain}"
    fi

    success "Certificates obtained successfully for ${main_domain} (and SANs)."
}

# =============================================================================
# apply_letsencrypt_standalone() - Request Let's Encrypt Certificate (Primary Function)
# =============================================================================
#
# CRITICAL FUNCTION - STRICT SEQUENCE ENFORCEMENT
#
# Purpose:
#   This is the PRIMARY function used in run_interactive_setup() to obtain
#   a single Let's Encrypt certificate using Certbot --standalone.
#
#   It requests ONE certificate where:
#     • The user-chosen main_domain becomes the Primary Common Name (CN)
#     • All additional domains become Subject Alternative Names (SANs)
#
# Alignment with CRITICAL REQUIREMENTS (Header - Single Source of Truth):
#   • Step 5: Ensure nginx is stopped → then run Certbot using the user-chosen main domain
#   • Step 6: ONLY AFTER certificates are successfully applied → setup full Nginx configuration
#   • The main domain is decided interactively by the user (get_main_domain())
#     and MUST be placed FIRST in the final domain list.
#   • Email and domains are handled independently BEFORE this function runs.
#
# Why --standalone (NOT --nginx plugin)?
#   • Prevents Certbot from modifying Nginx config prematurely.
#   • Allows clean separation: Certbot (internal certificate provider) finishes first,
#     then Nginx (external servant) receives its final configuration.
#   • Avoids common failures with partial setups or broken nginx configs.
#
# Defensive Design Rules Applied:
#   • ALWAYS call ensure_letsencrypt_structure() first (never assume paths exist).
#   • Stop port 80 again (redundant safety — in case something restarted nginx).
#   • Force main_domain to be the primary CN by constructing the domain list carefully.
#   • Strong input validation with die() on missing parameters.
#   • Post-issuance verification that the certificate files exist under ${main_domain}.
#   • All output goes through central functions (info / die / success).
#
# Important Notes:
#   • This function is intentionally more complete than apply_certificates().
#     It includes extra domain cleaning and --allow-subset-of-names for robustness.
#   • Duplication of port 80 stop is deliberate (defense in depth).
#   • The certificate will be stored at: /etc/letsencrypt/live/${main_domain}/
#
# LESSON LEARNED (April 2026 - Critical for Domain Expansion):
#   When adding a new domain to an existing certificate (e.g. adding slip.nifty-corner.com
#   to a cert that already contains crms.hk + other domains), Certbot will stop with:
#     "You have an existing certificate that contains a portion of the domains you requested"
#     and ask whether to expand the certificate.
#
#   Because the script runs with --non-interactive, this prompt causes failure.
#
#   SOLUTION:
#   • Always include --expand on the primary certbot call when domains may change.
#   • Use --cert-name "$main_domain" to make behavior explicit and reliable.
#   • Provide a fallback (without --expand) for the very first certificate issuance.
#   • This prevents the "expand" confirmation error when the domain list grows.
#
#   Recommended command pattern:
#     certbot certonly --standalone --expand --cert-name "$main_domain" --domains ...
#
# !!! THIS FUNCTION MUST BE CALLED ONLY AFTER stop_nginx_early() !!!
# !!! DO NOT MOVE THIS AFTER deploy_domain_nginx_configs() !!!
# !!! DO NOT USE --nginx PLUGIN IN THE MAIN INTERACTIVE FLOW !!!
# !!! THE USER-CHOSEN MAIN DOMAIN MUST REMAIN THE FIRST DOMAIN IN THE LIST !!!
# !!! ALWAYS INCLUDE --expand + --cert-name TO SUPPORT DOMAIN EXPANSION !!!
# =============================================================================

apply_letsencrypt_standalone() {
    local domains="$1"
    local email="$2"
    local main_domain="$3"

    ensure_letsencrypt_structure

    [ -z "$domains" ]     && die "No domains provided to apply_letsencrypt_standalone()"
    [ -z "$email" ]       && die "No email provided to apply_letsencrypt_standalone()"
    [ -z "$main_domain" ] && die "No main domain provided to apply_letsencrypt_standalone()"

    info "Stopping any service on port 80 (defense in depth)..."
    systemctl stop nginx 2>/dev/null || true
    fuser -k 80/tcp 2>/dev/null || true
    sleep 2

    local cert_domains_comma
    cert_domains_comma=$(echo "$domains" | tr ' ' ',')

    info "Requesting Let's Encrypt certificate with ${main_domain} as primary domain..."

    # Primary attempt: use --expand (best when adding domains to an existing cert)
    if ! certbot certonly --standalone \
        --email "$email" \
        --agree-tos \
        --non-interactive \
        --expand \
        --cert-name "$main_domain" \
        --domains "$cert_domains_comma"; then

        # Fallback for completely new certificate (first run)
        info "→ Expand not applicable (new certificate), falling back..."
        certbot certonly --standalone \
            --email "$email" \
            --agree-tos \
            --non-interactive \
            --allow-subset-of-names \
            --cert-name "$main_domain" \
            --domains "$cert_domains_comma" || die "Certbot failed to obtain certificates."
    fi

    # Critical verification
    if [ ! -f "/etc/letsencrypt/live/${main_domain}/fullchain.pem" ]; then
        die "Certificate files were not created under the main domain: ${main_domain}"
    fi

    success "✅ Let's Encrypt certificates obtained successfully."
    success "Primary certificate directory: /etc/letsencrypt/live/${main_domain}/"
}

# =============================================================================
# get_main_domain() - Authoritative Main Domain Input
# =============================================================================
#
# CRITICAL FUNCTION - DO NOT SIMPLIFY OR REFACTOR
#
# Purpose:
#   This is the SINGLE place where the user interactively and explicitly chooses
#   the PRIMARY / MAIN domain. 
#
#   According to the CRITICAL REQUIREMENTS:
#   • The main domain is chosen by the USER interactively.
#   • It is NOT determined by list position.
#   • This value becomes the Common Name (CN) of the certificate.
#   • All other domains added later become SANs only.
#   • Prints ALL output to stderr so it is never captured by command substitution.
#
# Behavior:
#   • Only runs in interactive TTY mode.
#   • Rejects placeholder domains (example, localhost, 1.8.0.0.1).
#   • Cleans and lowercases the domain.
#   • Returns the clean main domain chosen by the user.
#
# This function must be called BEFORE ask_and_confirm_domains().
# The returned value MUST be preserved and later forced to the front of the
# final domain list.
#
# !!! THIS IS THE AUTHORITATIVE DECISION POINT FOR THE MAIN DOMAIN !!!
# !!! DO NOT MOVE THIS LOGIC OR TRY TO DERIVE MAIN DOMAIN FROM LIST !!!
# =============================================================================

get_main_domain() {
    if [ "$TTY" = "0" ]; then
        die "Cannot get main domain in non-interactive mode. Run interactively."
    fi
    local main_domain=""

    ui_empty_line
    ui_info "Please enter your PRIMARY domain (this will be the main certificate name):"
    
    while true; do
        read -rp "  Primary domain (e.g. git.crms.hk): " input
        
        # Clean and validate input
        main_domain=$(echo "$input" | tr -dc 'a-zA-Z0-9.-' | tr '[:upper:]' '[:lower:]')

        if [ -n "$main_domain" ] && \
        ! echo "$main_domain" | grep -qE '(example|localhost|127\.0\.0\.1|local|test)'; then
            ui_success "✅ Primary domain accepted: ${main_domain}"
            echo "$main_domain"
            return 0
        fi

        ui_warn "Please enter a valid domain name."
        ui_warn "It cannot be empty, localhost, example.com, or similar placeholders."
    done
}

# =============================================================================
# install_nginx() - Install Nginx (Cross-Platform Support)
# =============================================================================
#
# CRITICAL FUNCTION - PART OF THE STRICT INSTALLATION SEQUENCE
#
# Purpose:
#   Installs the base `nginx` package **without** any custom configuration.
#
# Alignment with CRITICAL REQUIREMENTS (Header - Single Source of Truth):
#   • Step 2: Install Nginx without configuration
#   • Step 3: Stop Nginx service early (handled in stop_nginx_early())
#   • Full sequence must be preserved:
#       Install packages → Stop nginx early → Handle email & domains independently
#       → Apply certificates (standalone) → ONLY THEN setup full Nginx configuration
#
# Recent Improvement (April 2026 - Idempotency Enhancement):
#   • Strengthened early check: now verifies both `command -v nginx` AND that
#     the binary is executable (`[ -x "$(command -v nginx)" ]`).
#   • If nginx already exists, the function returns immediately with clear
#     status message (supports --json and normal mode).
#   • This prevents redundant package manager operations on repeated runs
#     while keeping the function fully idempotent and safe for automation.
#   • Improves Caution without touching any protected installation sequence.
#
# Platform Support Strategy (2026):
#   1. Linux:
#      • Debian/Ubuntu family          → apt-get
#      • Alpine Linux                  → apk
#      • RHEL/Fedora/Rocky/CentOS/Amazon Linux → dnf (with EPEL if needed)
#   2. macOS                           → Homebrew (brew)
#   3. Git Bash / MSYS2 / native Windows → Not recommended for production.
#      Strong warning + suggestion to use WSL2.
#   4. Other (openSUSE, etc.)          → Basic zypper support with fallback warning.
#
# Why Native Packages?
#   • Provides best integration with the OS (init system, paths, security).
#   • On Linux, the nginx package usually starts the service automatically after install.
#     This is expected behavior — we deliberately stop it in stop_nginx_early() to keep
#     port 80 free for Certbot --standalone.
#   • Homebrew on macOS is clean and widely used.
#   • Avoids compiling from source (too complex and error-prone for a one-command script).
#
# Defensive Design Rules Applied:
#   • Detect platform using `uname` and common package managers.
#   • Check if nginx is already installed before attempting install (idempotent).
#   • Run package manager update where appropriate.
#   • All output goes through central `info()` / `warn()` / `die()` functions.
#   • Fail with clear, actionable messages for unsupported or problematic environments.
#   • No configuration files touched here — that happens only in deploy_domain_nginx_configs().
#
# Important Notes:
#   • After installation on most Linux distros, nginx service is enabled and started.
#     This is why stop_nginx_early() must run immediately after.
#   • On macOS, Homebrew installs nginx but does not start it automatically.
#   • Git Bash / MSYS2 has very limited nginx support — native Windows nginx exists
#     but lacks full POSIX features expected by this script.
#
# !!! THIS FUNCTION MUST REMAIN EARLY IN run_interactive_setup() !!!
# !!! DO NOT ADD ANY CONFIGURATION, START, OR ENABLE COMMANDS HERE !!!
# !!! DO NOT COMBINE WITH deploy_domain_nginx_configs() !!!
# !!! THE OFFICIAL PACKAGE OFTEN STARTS NGINX — WE STOP IT RIGHT AFTER !!!
# =============================================================================

install_nginx() {
    if command -v nginx >/dev/null 2>&1 && [ -x "$(command -v nginx)" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "status" "nginx already installed" "path" "$(command -v nginx)"
        else
            info "nginx is already installed."
        fi
        return 0
    fi

    info "nginx not found → attempting platform-specific installation..."

    # Detect platform
    local OS
    OS=$(uname -s 2>/dev/null | tr '[:upper:]' '[:lower:]')

    case "$OS" in
        linux*)
            # Debian / Ubuntu family
            if command -v apt-get >/dev/null 2>&1; then
                info "Debian/Ubuntu detected → installing nginx via apt-get..."
                apt-get update -qq || warn "apt-get update failed (continuing)"
                apt-get install -y nginx || die "Failed to install nginx via apt-get."
                info "nginx installed successfully via apt-get."
                return 0
            fi

            # Alpine Linux
            if command -v apk >/dev/null 2>&1; then
                info "Alpine Linux detected → installing nginx via apk..."
                apk update || warn "apk update failed (continuing)"
                apk add --no-cache nginx || die "Failed to install nginx via apk."
                info "nginx installed successfully via apk."
                return 0
            fi

            # RHEL / Fedora / Rocky / CentOS / Amazon Linux (dnf or yum)
            if command -v dnf >/dev/null 2>&1 || command -v yum >/dev/null 2>&1; then
                info "RHEL-based system detected → installing nginx via dnf/yum..."
                if command -v dnf >/dev/null 2>&1; then
                    dnf install -y epel-release 2>/dev/null || true   # EPEL for older systems if needed
                    dnf install -y nginx || die "Failed to install nginx via dnf."
                else
                    yum install -y epel-release 2>/dev/null || true
                    yum install -y nginx || die "Failed to install nginx via yum."
                fi
                info "nginx installed successfully via dnf/yum."
                return 0
            fi

            # openSUSE / SUSE (zypper) - minimal support
            if command -v zypper >/dev/null 2>&1; then
                info "openSUSE detected → installing nginx via zypper..."
                zypper refresh -y || warn "zypper refresh failed"
                zypper install -y nginx || die "Failed to install nginx via zypper."
                info "nginx installed successfully via zypper."
                return 0
            fi

            die "Linux detected but no supported package manager (apt/apk/dnf/yum/zypper) found. Please install nginx manually."
            ;;

        darwin*)  # macOS
            if command -v brew >/dev/null 2>&1; then
                info "macOS detected → installing nginx via Homebrew..."
                brew update && brew install nginx || die "Failed to install nginx via Homebrew."
                info "nginx installed successfully via Homebrew."
                return 0
            else
                die "Homebrew not found on macOS. Please install Homebrew first[](https://brew.sh/) then rerun the script."
            fi
            ;;

        *)
            # Git Bash / MSYS2 / native Windows / unknown
            if [ -n "${MSYSTEM:-}" ] || echo "$OS" | grep -q "mingw\|msys"; then
                warn "Git Bash / MSYS2 detected."
                die "Nginx is not reliably supported in Git Bash. Recommended solutions:\n  • Use WSL2 with Ubuntu\n  • Install native Windows nginx from https://nginx.org/en/download.html (limited features)"
            else
                die "Unsupported operating system: ${OS}. This script supports Linux (apt/apk/dnf), macOS (Homebrew), and warns on Git Bash / Windows."
            fi
            ;;
    esac
}

# =============================================================================
# fix_docroot_permissions() - Set correct ownership for web files
# =============================================================================
#
# Purpose:
#   Ensures all document roots and HTML files are owned by www-data:www-data
#   (the default nginx user on Debian/Ubuntu and most Linux distros).
#
#   This prevents permission issues when serving static files.
#   Runs after deploy_domain_nginx_configs() so all directories and files exist.
#
# Defensive:
#   - Only runs as root
#   - Uses -R (recursive)
#   - Graceful on non-Debian systems (still tries common www-data)
#
# !!! DO NOT SIMPLIFY - permission issues are very common after certbot-nginx runs !!!
# =============================================================================

fix_docroot_permissions() {
    if [ "$(id -u)" -ne 0 ]; then
        return 0
    fi

    info "Fixing permissions: setting www-data:www-data ownership on document roots..."

    # Main docroots for all domains
    if [ -d "${NGINX_DOCROOT_BASE}" ]; then
        chown -R www-data:www-data ${NGINX_DOCROOT_BASE} 2>/dev/null || true
    fi

    # ACME challenge directory (used for renewals)
    if [ -d "${NGINX_DOCROOT_BASE}/letsencrypt" ]; then
        chown -R www-data:www-data ${NGINX_DOCROOT_BASE}/letsencrypt 2>/dev/null || true
    fi

    # Ensure directories are readable/executable and files are readable
    find ${NGINX_DOCROOT_BASE} -type d -exec chmod 755 {} + 2>/dev/null || true
    find ${NGINX_DOCROOT_BASE} -type f -exec chmod 644 {} + 2>/dev/null || true

    success "Document root permissions fixed (www-data:www-data)"
}

# =============================================================================
# create_cloudflare_map() - Create Cloudflare IP detection map (global, one-time)
# =============================================================================
#
# Purpose:
#   Creates the cloudflare-map.conf file and ensures it is included in nginx.conf.
#   This is a global (http context) configuration, not per-domain.
#
# Why separate function?
#   Cloudflare map is independent from per-domain server blocks.
#   Makes intention clear and allows easier future maintenance.
#
# Why Cloudflare IP Restriction?
#   When using Cloudflare, all visitor traffic arrives from Cloudflare's anycast network.
#   Blocking everything else prevents direct attacks, bypass of WAF, and reduces attack surface.
#   This is a common and recommended hardening practice for origins behind Cloudflare.
#
# Cloudflare IP Ranges:
#   Sourced from the official page: https://www.cloudflare.com/ips/
#   Last verified: April 2026
#   These ranges change infrequently. When they do, Cloudflare announces updates
#   on the same page before using them in production.
#
# Maintenance Note (Defensive):
#   • Keep this file static for reliability in one-command installs.
#   • To update ranges in the future:
#       curl -fsSL https://www.cloudflare.com/ips-v4 > /tmp/cf-ipv4
#       curl -fsSL https://www.cloudflare.com/ips-v6 > /tmp/cf-ipv6
#     Then manually merge into ${CLOUDFLARE_MAP_FILE} and re-run:
#       ${APP_NAME} nginx-conf
#   • Or implement a simple update script/hook later if needed.
#   • If access to / return 403, please use /cloudflare-check to inspect
#
# Problems found:
#   • nginx cannot check $remote_ip against ip map well, fall back to 
#     weak $http_cf_connecting_ip header at this stage.
#
# !!! CALLED ONLY ONCE FROM deploy_domain_nginx_configs() !!!
# =============================================================================

create_cloudflare_map() {
    local CLOUDFLARE_MAP_FILE="${NGINX_CONF_ROOT}/sites-available/cloudflare-map.conf"

    info "Creating Cloudflare IP detection map..."

    cat > "${CLOUDFLARE_MAP_FILE}" << 'EOF'
# =============================================================================
# Simple and Reliable $has_cf variable
# =============================================================================
map $remote_addr $origin_addr {
    default remote_addr;              # No header = direct access / not Cloudflare
}
map $http_cf_connecting_ip $has_cf {
    default "NO";                    # No header = direct access / not Cloudflare
    "~." "YES";                      # Any non-empty value = coming from Cloudflare
}

# === Cloudflare Real IP Configuration ===
# IPv4
set_real_ip_from 173.245.48.0/20;
set_real_ip_from 103.21.244.0/22;
set_real_ip_from 103.22.200.0/22;
set_real_ip_from 103.31.4.0/22;
set_real_ip_from 141.101.64.0/18;
set_real_ip_from 108.162.192.0/18;
set_real_ip_from 190.93.240.0/20;
set_real_ip_from 188.114.96.0/20;
set_real_ip_from 197.234.240.0/22;
set_real_ip_from 198.41.128.0/17;
set_real_ip_from 162.158.0.0/15;
set_real_ip_from 104.16.0.0/13;
set_real_ip_from 104.24.0.0/14;
set_real_ip_from 172.64.0.0/13;
set_real_ip_from 131.0.72.0/22;

# IPv6
set_real_ip_from 2400:cb00::/32;
set_real_ip_from 2606:4700::/32;
set_real_ip_from 2803:f800::/32;
set_real_ip_from 2405:b500::/32;
set_real_ip_from 2405:8100::/32;
set_real_ip_from 2a06:98c0::/29;
set_real_ip_from 2c0f:f248::/32;

EOF

    chmod 644 "${CLOUDFLARE_MAP_FILE}"
    ln -sf "${CLOUDFLARE_MAP_FILE}" ${NGINX_CONF_ROOT}/sites-enabled/

    if ! grep -q "cloudflare-map.conf" ${NGINX_CONF_ROOT}/nginx.conf; then
        sed -i "/http[[:space:]]*{/a \    include ${CLOUDFLARE_MAP_FILE};" ${NGINX_CONF_ROOT}/nginx.conf
    fi
}

# =============================================================================
# create_per_domain_server_blocks() - Create per-domain HTTPS configs
# =============================================================================
#
# Purpose:
#   Creates one server block per domain in sites-available/ and symlinks to sites-enabled/.
#   Includes document root, index.html, SSL, Cloudflare protection, etc.
#
# Why separate?
#   This is the domain-specific part. Clear separation improves readability
#   and maintainability without touching protected core logic.
#
#   It sets up a secure, production-ready Nginx configuration with:
#     • HTTP → HTTPS redirect + ACME challenge support
#     • Per-domain HTTPS server blocks using the SINGLE certificate
#       (main_domain as primary CN + all other domains as SANs)
#     • Strong Cloudflare-only origin protection (deny all other direct access)
#     • Proper real_ip handling so $remote_addr reflects the real visitor IP
#
# Security Model (Defensive Design):
#   • Only Cloudflare IPs are allowed to reach the server on port 443.
#   • Direct access from anywhere else is blocked (deny all;).
#   • This protects the origin server when placed behind Cloudflare Proxy (orange cloud).
#   • real_ip_recursive on + CF-Connecting-IP header gives correct client IP
#     to logs and any backend applications (e.g. GitLab, custom apps).
#   • SSL configuration is modern and secure (TLSv1.2 + TLSv1.3).
#
# Certificate Usage:
#   All domains (main + SANs) share ONE certificate located at:
#       /etc/letsencrypt/live/${main_domain}/
#   This is by design — one cert covers the entire list.
#
# =============================================================================
# CRITICAL WARNING - $is_cf IMPLEMENTATION (REAL SERVER TESTED)
# =============================================================================
#
# Problems discovered through real server testing:
#   • Using `geo $remote_addr $is_cf { ... }`                → buggy / unreliable
#   • Using `map $realip_remote_addr $is_cf { ... }`        → buggy / unreliable
#   • Any map/geo that depends on variables after real_ip module runs → often fails
#
# Working solution (verified on real server):
#   1. Capture original connecting IP very early:
#        map $remote_addr $origin_addr { default $remote_addr; }
#   2. Then inside server block:
#        set $is_cf 0;
#        if ($remote_addr != $origin_addr) {
#            set $is_cf 1;
#        }
#
# !!! CALLED FROM deploy_domain_nginx_configs() !!!
# =============================================================================

create_per_domain_server_blocks() {
    local domains="$1"
    local main_domain="$2"
    local cert_path="/etc/letsencrypt/live/${main_domain}"

    for domain in $domains; do
        mkdir -p "${NGINX_DOCROOT_BASE}/${domain}"
        chmod 755 "${NGINX_DOCROOT_BASE}/${domain}"

        cat > "${NGINX_DOCROOT_BASE}/${domain}/index.html" << EOF
<!DOCTYPE html><html><head><title>${domain}</title></head><body style="font-family:Arial;text-align:center;padding:100px;">
<h1>${domain}</h1><p>Protected by Cloudflare + Nginx</p></body></html>
EOF

        cat > "${NGINX_CONF_ROOT}/sites-available/${domain}.conf" << EOF

include ${NGINX_CONF_ROOT}/sites-available/cloudflare-map.conf;

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name ${domain};

    root ${NGINX_DOCROOT_BASE}/${domain};
    index index.html;

    ssl_certificate ${cert_path}/fullchain.pem;
    ssl_certificate_key ${cert_path}/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers off;

    # This must be inside server block
    set \$is_cf 0;
    if (\$remote_addr != \$origin_addr) {
        set \$is_cf 1;
    }

    # ====================== CLOUD FLARE CHECK PAGE ======================
    location = /cloudflare-check {
        default_type text/html;
        return 200 '
<!DOCTYPE html>
<html>
<head><title>Cloudflare Check - ${domain}</title></head>
<body style="font-family:Arial,sans-serif;text-align:center;padding:50px;background:#f8f9fa;">
    <h1>Cloudflare Check</h1>
    <p style="font-size:2.8em;color:#0066cc;font-weight:bold;">\$remote_addr</p>
    <p><strong>From Cloudflare?</strong> \$is_cf (1 = Yes)</p>
    <p><strong>CF Connecting IP:</strong> \$http_cf_connecting_ip</p>
    <p><strong>Is Cloudflare:</strong> <span style="color: #0066cc; font-weight:bold;">\$has_cf</span></p>
    <p><strong>Ray ID:</strong> \$http_cf_ray</p>
    <hr>
    <p style="color:green;">This page is open to everyone (bypassing protection)</p>
</body>
</html>';
    }
    # ============================================================

    location / {
        if (\$http_cf_connecting_ip = "") {
            return 403;
        }
        try_files \$uri \$uri/ =404;
    }

    location /.well-known/acme-challenge/ {
        root ${NGINX_DOCROOT_BASE}/letsencrypt;
        try_files \$uri =404;
    }
}
EOF

        ln -sf "${NGINX_CONF_ROOT}/sites-available/${domain}.conf" ${NGINX_CONF_ROOT}/sites-enabled/
    done
}

# =============================================================================
# deploy_domain_nginx_configs() - Final Nginx Configuration (After Certificates)
# =============================================================================
#
# CRITICAL FUNCTION - STRICT SEQUENCE ENFORCEMENT
#
# Purpose:
#   Creates and deploys the final nginx virtual host configuration for each domain
#   (after certificates are obtained).
#
#   High-level orchestrator called after certificates are obtained.
#   Coordinates the 4 distinct steps without doing the heavy work itself.
#
#   This includes:
#   • Cloudflare IP detection map (once)
#   • Per-domain HTTPS server blocks (with redirect, ACME support, etc.)
#   • Document root + index.html creation
#   • nginx-adm ownership
#
# Why this name?
#   Previous name `setup_nginx_configs` was too broad and vague.
#   New name clearly communicates the **intent**: deploying domain-specific
#   configs after the certificate stage.
#
# This method is currently the only reliable way found in real environment.
#
# !!! DO NOT START NGINX EARLIER !!!
# !!! THIS FUNCTION MUST RUN AFTER apply_letsencrypt_standalone() !!!
# !!! DO NOT MODIFY THE CORE STRUCTURE OR SECURITY MODEL !!!
# =============================================================================

deploy_domain_nginx_configs() {
    local domains="$1"
    local main_domain="$2"

    [ -z "$domains" ]     && die "No domains provided to deploy_domain_nginx_configs()"
    [ -z "$main_domain" ] && die "No main domain provided to deploy_domain_nginx_configs()"

    info "Deploying final Nginx configuration (after certificates)..."

    create_cloudflare_map
    create_per_domain_server_blocks "$domains" "$main_domain"
    setup_nginx_adm_ownership
    fix_docroot_permissions   # if you want to keep it here

    info "Nginx configuration completed successfully."
    info "→ Debug page is now available at: https://${main_domain}/cloudflare-check"
}

# =============================================================================
# run_interactive_setup() - Main Interactive Setup Flow
# =============================================================================
#
# CRITICAL FUNCTION - STRICT SEQUENCE ENFORCEMENT
#
# This function strictly follows the CRITICAL REQUIREMENTS defined in the main header.
#
# Key Logic for Main Domain:
#   • The PRIMARY / MAIN domain is chosen EXPLICITLY and INTERACTIVELY by the USER
#     via get_main_domain(). This is the authoritative decision.
#   • ask_and_confirm_domains() is ONLY used to let the user ADD extra domains (SANs).
#   • After confirmation, the script MUST re-arrange the final domain list so that
#     the user-chosen main domain is placed FIRST.
#   • Prints ALL output to stderr so it is never captured by command substitution.
#
# Platform Notes (2026):
#   • install_certbot() and install_nginx() now support multiple platforms.
#   • Core certificate and nginx config logic remains Linux-centric.
#   • On macOS, some systemd commands are skipped gracefully in stop_nginx_early().
#
# New in 1.9.0:
#   • Calls nginx-adm setup functions early
#   • Calls backup_nginx_sites_configs() before any configuration changes
#   • Uses nginx-adm for ownership and testing (least privilege)
#
# New Feature (April 2026):
#   • Added interactive question: "Are you using Cloudflare proxy?"
#   • Supports --no-cloudflare flag to skip the question and disable protection
#   • When using Cloudflare: warns user to temporarily set DNS to "DNS Only" (grey cloud)
#   • When not using Cloudflare: generates open Nginx config (allow all)
#
# Strict Sequence (MUST NOT BE CHANGED):
#   1. nginx-adm user + ownership + sudoers
#   2. Backup existing configs (with default.conf removal)
#   3. Install Certbot
#   4. Install Nginx
#   5. Stop Nginx early
#   6. Handle email and domains
#   7. Apply certificates
#   8. Setup Nginx configs
#   9. Test (as nginx-adm) and start
#
# Why this exact order?
#   - Prevents nginx from running with empty/broken config
#   - Allows clean Certbot --standalone operation on port 80
#   - Maintains clear separation: Certbot (cert provider) → Nginx (web server)
#
# !!! DO NOT MODIFY THIS SEQUENCE !!!
# !!! DO NOT START NGINX BEFORE CERTIFICATES ARE APPLIED !!!
# !!! DO NOT COMBINE STEPS OR TREAT CERTBOT AND NGINX AS EQUAL !!!
# =============================================================================

run_interactive_setup() {
    check_root
    ensure_letsencrypt_structure

    # === 1.9.0: nginx-adm Least-Privilege Setup ===
    create_nginx_adm_user
    setup_nginx_adm_ownership
    setup_restricted_sudoers

    # === 1.9.0: Backup before any config changes ===
    backup_nginx_sites_configs

    # Step 1-2: Install packages (no config)
    install_certbot
    install_nginx

    # Step 3: Stop Nginx early (critical)
    stop_nginx_early

    # Step 4: Email & Domains (independent handling)
    local email
    email=$(get_or_set_email)

    local main_domain
    local domains
    local domains_to_confirm

    domains=$(load_existing_domains)
    [ -n "$domains" ] && main_domain=$(get_main_domain_from_file "$domains")
    if [ -z "$main_domain" ]; then
        main_domain=$(get_main_domain)
    else
        ui_info "Using saved Let's Encrypt main domain: ${main_domain}"
    fi

    if [ -n "$domains" ]; then
        domains=$(echo "$domains" | tr ' ' '\n' | grep -v "^$main_domain$" | tr '\n' ' ' | sed 's/^ *//;s/ *$//')
        domains_to_confirm="$main_domain $domains"
        domains_to_confirm=$(echo "$domains_to_confirm" | tr -s ' ' | sed 's/^ *//;s/ *$//')
    else
        domains_to_confirm="$main_domain"
    fi

    domains=$(ask_and_confirm_domains "$domains_to_confirm")

    if [ -n "$main_domain" ] && [ -n "$domains" ]; then
        domains=$(echo "$domains" | tr ' ' '\n' | grep -v "^$main_domain$" | tr '\n' ' ' | sed 's/^ *//;s/ *$//')
        domains="$main_domain $domains"
        domains=$(echo "$domains" | tr -s ' ' | sed 's/^ *//;s/ *$//')
    fi
    save_domains_to_file "$domains"

    # Cloudflare Choice
    if [ "${USE_CLOUDFLARE}" -eq 1 ]; then
        if [ "$TTY" -eq 1 ]; then
            empty_line
            warn "=== Cloudflare Proxy Detection ==="
            msg "Are you running this server behind Cloudflare proxy (orange cloud)?"
            msg_n "Use Cloudflare protection? (Y/n): "
            read -r use_cf
            use_cf=$(echo "$use_cf" | tr '[:upper:]' '[:lower:]')
            
            if [ "$use_cf" = "n" ] || [ "$use_cf" = "no" ]; then
                USE_CLOUDFLARE=0
                info "Cloudflare protection disabled."
            else
                USE_CLOUDFLARE=1
                empty_line
                warn "IMPORTANT: During certificate issuance, please make sure your DNS record"
                warn "is set to DNS Only (grey cloud / no proxy)."
                warn "You can switch it back to Proxied (orange cloud) after setup completes."
                msg_n "Press Enter when you have set DNS to DNS Only..."
                read -r dummy
                info "Continuing with Cloudflare protection enabled."
            fi
        fi
    fi

    # Step 5: Apply certificates
    apply_letsencrypt_standalone "$domains" "$email" "$main_domain"

    # Step 6: Setup final Nginx configuration
    deploy_domain_nginx_configs "$domains" "$main_domain"

    # Step 7: Test and start nginx (as nginx-adm)
    info "Testing nginx configuration..."
    sudo nginx -t || die "Nginx config test failed!"

    info "Starting nginx service..."
    systemctl start nginx || warn "Failed to start nginx (check manually)"

    success "Nginx started successfully."
    success "Full setup completed for main domain: ${main_domain}"
    
    if [ "${USE_CLOUDFLARE}" -eq 1 ]; then
        success "Cloudflare IP restriction is ENABLED (direct access blocked)"
    else
        success "Cloudflare protection is DISABLED (open to all IPs)"
    fi

    success "nginx-adm least-privilege model is active."
}

