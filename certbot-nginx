# =============================================================================
# get_main_domain_from_file() - Extract Primary Domain from Domain List
# =============================================================================
#
# CRITICAL HELPER FUNCTION - DO NOT SIMPLIFY OR REMOVE
#
# Purpose:
#   Extracts the PRIMARY / MAIN domain from a space-separated domain list.
#   This function enforces the rule that the first domain in the final list
#   is always treated as the main domain for certificate and nginx configuration.
#
# Key Rules (Aligned with CRITICAL REQUIREMENTS):
#   • The main domain is decided interactively by the user via get_main_domain().
#   • After confirmation and re-arrangement, this function returns the domain
#     that must be placed FIRST in the saved list.
#   • It is used to safely get the primary domain for:
#       - Certificate request (as Common Name)
#       - Certificate path (/etc/letsencrypt/live/${main_domain}/...)
#       - Nginx configuration
#
# Input:
#   $1 = space-separated string of domains (e.g. "git.example.com app.example.com")
#
# Output:
#   The first domain in the list, or empty string if input is empty.
#
# Important:
#   This function should be called AFTER forcing the user-chosen main domain
#   to the front of the list in run_interactive_setup().
#
# !!! THIS FUNCTION IS PART OF THE DEFENSIVE "MAIN DOMAIN HANDLING" CHAIN !!!
# !!! DO NOT MODIFY ITS BEHAVIOR !!!
# =============================================================================

get_main_domain_from_file() {
    local domains="$1"

    if [ -z "$domains" ]; then
        echo ""
        return 0
    fi

    # Extract first domain safely
    echo "$domains" | awk '{print $1}'
}


