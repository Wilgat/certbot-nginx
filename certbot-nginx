# =============================================================================
# ensure_letsencrypt_structure() - Defensive Directory & File Pre-Creation
# =============================================================================
#
# CRITICAL DEFENSIVE FUNCTION - DO NOT SIMPLIFY, REMOVE, OR REFACTOR
#
# Purpose:
#   This function enforces the "Defensive Pre-Creation Rule" defined in the
#   main CRITICAL REQUIREMENTS section.
#
#   It MUST be called early in every major code path (interactive setup,
#   non-interactive setup, nginx-conf, show_domains, etc.) BEFORE any
#   operation that reads or writes email.conf or domains.conf.
#
# Rules This Function Must Always Follow:
#   • NEVER assume that /etc/letsencrypt or its subdirectories exist.
#   • ALWAYS create the full directory structure if missing.
#   • ALWAYS ensure the placeholder files (email.conf and domains.conf) exist.
#   • Use strict permissions: email.conf = 600, domains.conf = 644.
#   • This function is intentionally called redundantly for maximum safety.
#
# Why This Function Exists:
#   - Certbot may not have created these paths yet.
#   - The script must survive fresh systems, partial installs, or interrupted runs.
#   - It supports independent email/domain handling before any Certbot command runs.
#
# Important:
#   This is part of the "Do Not Rely On Certbot" defensive strategy.
#   Removing or simplifying this function will break the reliability of the entire script.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# !!! CALL IT EARLY AND OFTEN !!!
# =============================================================================

ensure_letsencrypt_structure() {
    mkdir -p /etc/letsencrypt
    mkdir -p /etc/letsencrypt/renewal
    mkdir -p /etc/letsencrypt/live
    mkdir -p /etc/letsencrypt/archive

    # Create placeholder files if missing
    if [ ! -f "$EMAIL_FILE" ]; then
        touch "$EMAIL_FILE"
        chmod 600 "$EMAIL_FILE"
    fi

    if [ ! -f "$DOMAINS_FILE" ]; then
        touch "$DOMAINS_FILE"
        chmod 644 "$DOMAINS_FILE"
    fi
}

# =============================================================================
# load_existing_domains() - Load Previously Saved Domain List
# =============================================================================
#
# CRITICAL SUPPORT FUNCTION - DO NOT SIMPLIFY OR REMOVE
#
# Purpose:
#   This function loads the previously saved domain list from 
#   /etc/letsencrypt/domains.conf.
#
#   It is part of the "Email and Domain List Handling MUST be done FIRST 
#   and INDEPENDENTLY" requirement.
#
# Defensive Rules Applied:
#   • Always call ensure_letsencrypt_structure() first (never assume files exist).
#   • Return a clean space-separated list of domains (or empty string if none).
#   • This function does NOT decide the main domain — it only loads what was saved.
#   • The main domain is decided interactively by the user via get_main_domain().
#   • After loading, the script must ensure the user-chosen main domain is placed first.
#
# Output:
#   Returns a single line containing domains separated by single spaces.
#   Returns empty string if file does not exist or is empty.
#
# Usage:
#   Called early in run_interactive_setup() to check if domains were previously configured.
#
# !!! This function supports the defensive design where domains are handled 
#     independently of Certbot and Nginx configuration !!!
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# =============================================================================

load_existing_domains() {
    ensure_letsencrypt_structure

    # Non-root graceful fallback - no config directory yet
    if [ "$(id -u)" -ne 0 ] && [ ! -f "$DOMAINS_FILE" ]; then
        echo ""
        return 0
    fi

    if [ -f "$DOMAINS_FILE" ] && [ -s "$DOMAINS_FILE" ]; then
        tr -s ' \t\n\r' ' ' < "$DOMAINS_FILE" | sed 's/^ *//;s/ *$//' | tr -d '\n'
    else
        echo ""
    fi
}

# =============================================================================
# show_domains() - Display Currently Saved Domains
# =============================================================================
#
# Purpose:
#   Shows the saved domain list from /etc/letsencrypt/domains.conf.
#   This is a diagnostic / user command (`${APP_NAME} domains`).
#
# Rules This Function Must Follow:
#   • Must respect --quiet and --json modes (use output_text / output_json).
#   • Must call ensure_letsencrypt_structure() first (defensive).
#   • Must clearly show that the first domain is the main/primary domain.
#   • Output must be clean and consistent with the rest of the script.
#
# Works for both root and non-root users.
# Gracefully handles missing configuration without permission errors.
#
# Important:
#   This command is for human inspection only. It does not modify any data.
#
# !!! DO NOT SIMPLIFY THIS FUNCTION !!!
# !!! ALL OUTPUT MUST GO THROUGH THE CENTRAL OUTPUT FUNCTIONS !!!
# =============================================================================

show_domains() {
    ensure_letsencrypt_structure

    # Non-root graceful fallback when config directory/files don't exist yet
    if [ "$(id -u)" -ne 0 ] && [ ! -f "$DOMAINS_FILE" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "status" "No domains configured yet. Run: sudo ${APP_NAME}"
        else
            warn "No domains configured yet at ${DOMAINS_FILE}"
            msg "Run 'sudo ${APP_NAME}' to perform the full setup."
        fi
        return 0
    fi

    if [ "${JSON}" -eq 1 ]; then
        local domains
        domains=$(load_existing_domains)

        if [ -z "$domains" ]; then
            output_json "status" "No domains configured yet"
        else
            local json_array
            json_array=$(echo "$domains" | tr ' ' '\n' | jq -R -s -c 'split("\n")[:-1]' 2>/dev/null || echo "[]")
            output_json "success" "" \
                "domains" "$json_array" \
                "count" "$(echo "$domains" | wc -w | tr -d ' ')" \
                "primary" "$(get_main_domain_from_file "$domains")"
        fi
        return 0
    fi

    if [ "${QUIET}" -eq 1 ]; then
        return 0
    fi

    if [ -f "$DOMAINS_FILE" ] && [ -s "$DOMAINS_FILE" ]; then
        local domains count
        domains=$(load_existing_domains)
        count=$(echo "$domains" | wc -w | tr -d ' ')

        msg "=== Saved Domains in ${DOMAINS_FILE} ==="
        msg "Total domains: ${count} (First domain = Primary/Main domain)"
        empty_line
        
        for d in $domains; do
            if [ "$d" = "$(get_main_domain_from_file "$domains")" ]; then
                success "→ ${d}  (Primary Domain)"
            else
                msg "  ${d}"
            fi
        done
    else
        warn "No domains configured yet at ${DOMAINS_FILE}"
        msg "Run 'sudo ${APP_NAME}' to perform the full setup."
    fi
}

